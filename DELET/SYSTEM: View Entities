-- ==========================================
-- CONFIGURAÇÕES VISUAIS & DISTÂNCIA
-- ==========================================
local MAX_DISTANCE = 2000 -- Distância máxima de detecção (aumentado para prever)
local FADE_START = 800    -- Começa a sumir de longe para não poluir a tela
local UPDATE_RATE = 0.5   -- Scanner rápido (0.5s)

local STROKE_COLOR = Color3.fromRGB(255, 60, 0) -- Laranja intenso Doors
local OUTLINE_COLOR = Color3.fromRGB(255, 0, 0)  -- Vermelho Alerta intenso
local DIST_COLOR = "#FFD700" -- Dourado
local HP_COLOR = "#FF3232"

