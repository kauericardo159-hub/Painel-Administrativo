local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- GERENCIADOR DE VELOCIDADE (Aplicação Direta)
-- ==========================================

-- Removemos o controle de _G.SystemSpeedConnection para que ele 
-- execute a aplicação diretamente ao ser chamado.

local function applySpeedToCharacter()
    local char = localPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    -- Busca o valor do TextBox "ValueInput"
    local playerGui = localPlayer:WaitForChild("PlayerGui")
    local coreGui = playerGui:WaitForChild("SistemaPainel_V3", 5)
    
    if not coreGui then return end
    
    local speedInput = coreGui:WaitForChild("Panel"):WaitForChild("ListaOpcoesContainer"):WaitForChild("SpeedControlCard"):WaitForChild("ValueInput")
    local targetSpeed = tonumber(speedInput.Text) or 16
    
    -- Aplica a velocidade se for diferente da atual
    if hum.WalkSpeed ~= targetSpeed then
        hum.WalkSpeed = targetSpeed
    end
end

-- ==========================================
-- APLICAÇÃO E PERSISTÊNCIA
-- ==========================================

-- 1. Aplica imediatamente ao chamar o script
applySpeedToCharacter()

-- 2. Garante persistência se o personagem renascer
localPlayer.CharacterAdded:Connect(function(newCharacter)
    applySpeedToCharacter()
end)

-- 3. Loop de segurança (roda apenas uma vez para garantir que o alvo seja mantido)
if not _G.SpeedLoopRunning then
    _G.SpeedLoopRunning = true
    RunService.Heartbeat:Connect(function()
        applySpeedToCharacter()
    end)
end

print("[SYSTEM] Speed: Aplicação de velocidade ativada.")
