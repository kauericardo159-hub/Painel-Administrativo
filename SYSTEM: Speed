local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE PERSISTÊNCIA (Anti-Reset)
-- ==========================================

-- Se o sistema já estiver rodando, apenas atualizamos o alvo de velocidade.
-- Se não estiver, iniciamos o loop de segurança.

-- Função principal de aplicação de velocidade
local function applySpeed(speed)
    local char = localPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = speed
    end
end

-- ==========================================
-- GERENCIADOR DE ESTADO (LIGA/DESLIGA)
-- ==========================================

-- Definimos uma variável global para controlar o loop
if not _G.SystemSpeedConnection then
    print("[SYSTEM] Speed: INICIADO")
    
    -- Loop de alta performance para forçar a velocidade
    _G.SystemSpeedConnection = RunService.Heartbeat:Connect(function()
        if _G.TargetSpeed then
            applySpeed(_G.TargetSpeed)
        end
    end)
    
    -- Limpeza ao sair do jogo
    localPlayer.AncestryChanged:Connect(function()
        if not localPlayer:IsDescendantOf(game) then
            if _G.SystemSpeedConnection then _G.SystemSpeedConnection:Disconnect() end
            _G.TargetSpeed = nil
        end
    end)
end

-- ==========================================
-- LÓGICA DE APLICAR/RESETAR
-- ==========================================
-- O MiniPainel chamará este script. Precisamos saber se é para aplicar ou resetar.
-- Para isso, usaremos uma variável temporária definida pelo botão do painel.

if _G.Action == "Apply" then
    -- Busca o valor do TextBox
    local playerGui = localPlayer:WaitForChild("PlayerGui")
    local coreGui = playerGui:WaitForChild("SistemaPainel_V3", 5)
    local speedInput = coreGui:WaitForChild("Panel"):WaitForChild("ListaOpcoesContainer"):WaitForChild("SpeedControlCard"):WaitForChild("ValueInput")
    
    _G.TargetSpeed = tonumber(speedInput.Text) or 16
    print("[SYSTEM] Speed Aplicado: " .. _G.TargetSpeed)
    applySpeed(_G.TargetSpeed)
    
elseif _G.Action == "Reset" then
    _G.TargetSpeed = 16
    print("[SYSTEM] Speed Resetado")
    applySpeed(16)
end
