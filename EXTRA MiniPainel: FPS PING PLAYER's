local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

--[[ 
===========================================================
       ⚙ MINI-PAINEL EXTRA: FPS | PING | PLAYERS V2 ⚙
===========================================================
]]

-- 1. LOCALIZAÇÃO NA LISTA EXTRA
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3")
local painel = coreGui:WaitForChild("Panel")
local extraLista = painel:WaitForChild("ExtraListContainer")

local functionName = "FPSPingCard"
local saveKey = "FPSPingStatus"

-- Limpeza de duplicatas
if extraLista:FindFirstChild(functionName) then
    extraLista[functionName]:Destroy()
end

-- 2. CRIAÇÃO DO MINI-PAINEL (Altura Reduzida)
local miniPainel = Instance.new("Frame")
miniPainel.Name = functionName
miniPainel.Size = UDim2.new(0.95, 0, 0, 50) -- ✅ Altura reduzida para 50
miniPainel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
miniPainel.BackgroundTransparency = 0.4
miniPainel.BorderSizePixel = 0
miniPainel.ZIndex = extraLista.ZIndex + 1
miniPainel.Parent = extraLista

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = miniPainel

-- ✅ UIStroke AZUL ESCURO
local strokeAzul = Instance.new("UIStroke")
strokeAzul.Thickness = 2
strokeAzul.Color = Color3.fromRGB(0, 50, 150)
strokeAzul.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
strokeAzul.Parent = miniPainel

-- ✅ UIStroke PRETO ANIMADO (Efeito de brilho)
local strokePreto = Instance.new("UIStroke")
strokePreto.Thickness = 4
strokePreto.Color = Color3.fromRGB(0, 0, 0)
strokePreto.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
strokePreto.Transparency = 1
strokePreto.Parent = miniPainel

-- 3. ANIMAÇÃO DO UIStroke PRETO
task.spawn(function()
    while miniPainel.Parent do
        local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
        local fadeOut = TweenService:Create(strokePreto, tweenInfo, {Transparency = 1})
        local fadeIn = TweenService:Create(strokePreto, tweenInfo, {Transparency = 0.5})
        fadeIn:Play()
        fadeIn.Completed:Wait()
        fadeOut:Play()
        fadeOut.Completed:Wait()
    end
end)

-- 4. TÍTULO E TOGGLE (Lado a Lado)
local title = Instance.new("TextLabel")
title.Size = UDim2.new(0.6, -10, 1, 0) -- Largura ajustada
title.Position = UDim2.new(0, 10, 0, 0)
title.BackgroundTransparency = 1
title.Text = "FPS | PING | PLAYERS"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = miniPainel

-- Lógica de Estado
local isActive = false
if _G[saveKey] ~= nil then
    isActive = _G[saveKey]
else
    isActive = false
end

-- Botão (Switch) - Reposicionado ao lado do título
local btnBase = Instance.new("TextButton")
btnBase.Size = UDim2.new(0, 50, 0, 25)
btnBase.Position = UDim2.new(1, -60, 0.5, 0) -- Posição à direita
btnBase.AnchorPoint = Vector2.new(0, 0.5)
btnBase.Text = ""
btnBase.AutoButtonColor = false
btnBase.Parent = miniPainel -- Parent ajustado

Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)

-- ✅ UIStroke BRANCO no Botão (Para destacar do fundo)
local btnStroke = Instance.new("UIStroke")
btnStroke.Thickness = 2
btnStroke.Color = Color3.fromRGB(255, 255, 255)
btnStroke.Parent = btnBase

-- Knob (Círculo)
local knob = Instance.new("Frame")
knob.Size = UDim2.new(0, 19, 0, 19)
knob.Position = isActive and UDim2.new(1, -22, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
knob.AnchorPoint = Vector2.new(0, 0.5)
knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
knob.Parent = btnBase
Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

-- Cores
local colorInactiveBase = Color3.fromRGB(100, 0, 0) -- Red Escuro
local colorInactiveStroke = Color3.fromRGB(255, 0, 0) -- Red Forte
local colorActiveBase = Color3.fromRGB(0, 80, 0) -- Verde Escuro
local colorActiveStroke = Color3.fromRGB(0, 255, 0) -- Verde Forte

local function UpdateVisual(instant)
    local targetPos = isActive and UDim2.new(1, -22, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
    local targetBaseColor = isActive and colorActiveBase or colorInactiveBase
    local targetStrokeColor = isActive and colorActiveStroke or colorInactiveStroke
    
    if instant then
        knob.Position = targetPos
        btnBase.BackgroundColor3 = targetBaseColor
        btnStroke.Color = targetStrokeColor
    else
        TweenService:Create(knob, TweenInfo.new(0.3), {Position = targetPos}):Play()
        TweenService:Create(btnBase, TweenInfo.new(0.3), {BackgroundColor3 = targetBaseColor}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.3), {Color = targetStrokeColor}):Play()
    end
end

-- Inicializa visual
UpdateVisual(true)

-- 5. LÓGICA DE CLIQUE E loadstring (Corrigida)
btnBase.MouseButton1Click:Connect(function()
    isActive = not isActive
    _G[saveKey] = isActive 
    UpdateVisual(false)
    
    if isActive then
        -- COLE SEU LOADSTRING AQUI
        print("Ativando Monitor FPS...")
        loadstring(game:HttpGet("https://raw.githubusercontent.com/kauericardo159-hub/Painel-Administrativo/refs/heads/main/EXTRA%20SYSTEM%3A%20FPS%20PING%20PLAYER's"))()
    else
        print("Desativando Monitor FPS...")
        -- Se o script precisar de uma lógica para desativar, coloque aqui
    end
end)

-- 6. ANIMAÇÃO DE ENTRADA DO CARD
miniPainel.Position = UDim2.new(1.2, 0, 0, 0)
TweenService:Create(miniPainel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()

print("✅ MiniPainel Extra FPS/Ping V2 Carregado!")
