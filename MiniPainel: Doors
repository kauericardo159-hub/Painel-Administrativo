-- ==========================================
-- 3. FUNÇÃO DE TOGGLE (LOGICA CORRIGIDA)
-- ==========================================
local function CreateToggle(name, labelText, posX, saveKey, url)
    local container = Instance.new("Frame")
    container.Name = name .. "Container"
    container.Size = UDim2.new(0.3, 0, 0, 60)
    container.Position = UDim2.new(posX, 0, 0.65, 0)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.ZIndex = miniPainel.ZIndex + 1
    container.Parent = miniPainel

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 20)
    iconLabel.Text = labelText
    iconLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    iconLabel.Font = Enum.Font.GothamMedium
    iconLabel.TextSize = 10
    iconLabel.BackgroundTransparency = 1
    iconLabel.ZIndex = container.ZIndex + 1
    iconLabel.Parent = container

    local btnBase = Instance.new("TextButton")
    btnBase.Size = UDim2.new(0, 42, 0, 18)
    btnBase.Position = UDim2.new(0.5, 0, 0.7, 0)
    btnBase.AnchorPoint = Vector2.new(0.5, 0.5)
    btnBase.Text = ""
    btnBase.AutoButtonColor = true
    btnBase.ZIndex = container.ZIndex + 2
    btnBase.Parent = container
    Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1.5
    btnStroke.Parent = btnBase

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.ZIndex = btnBase.ZIndex + 1
    knob.Parent = btnBase
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Sincronização inicial
    if _G[saveKey] == nil then _G[saveKey] = false end

    local function UpdateVisual(instant)
        local active = _G[saveKey]
        local targetPos = active and UDim2.new(1, -15, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        local bgColor = active and Color3.fromRGB(200, 120, 0) or Color3.fromRGB(60, 60, 60)
        local strokeColor = active and Color3.fromRGB(255, 180, 0) or Color3.fromRGB(100, 100, 100)

        if instant then
            knob.Position = targetPos
            btnBase.BackgroundColor3 = bgColor
            btnStroke.Color = strokeColor
        else
            TweenService:Create(knob, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Position = targetPos}):Play()
            TweenService:Create(btnBase, TweenInfo.new(0.25), {BackgroundColor3 = bgColor}):Play()
            TweenService:Create(btnStroke, TweenInfo.new(0.25), {Color = strokeColor}):Play()
        end
    end

    UpdateVisual(true)

    -- ✅ CORREÇÃO: Executa o script EM TODOS OS CLIQUES para permitir o Toggle interno
    btnBase.Activated:Connect(function()
        _G[saveKey] = not _G[saveKey]
        UpdateVisual(false)
        
        -- Executa sempre, o script de destino decide se liga ou desliga
        task.spawn(function()
            loadstring(game:HttpGet(url))()
        end)
    end)
end

