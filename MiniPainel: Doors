-- 3. FUNÇÃO PARA CRIAR OS TOGGLES (Igual ao View Player)
local function CreateToggle(name, labelText, posX, loadstringFunction)
    local container = Instance.new("Frame")
    container.Name = name .. "Container"
    container.Size = UDim2.new(0.3, 0, 0, 65)
    container.Position = UDim2.new(posX, 0, 0.65, 0)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.Parent = miniPainel

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 20)
    iconLabel.Position = UDim2.new(0, 0, -0.1, 0)
    iconLabel.Text = labelText
    iconLabel.TextColor3 = Color3.new(1, 1, 1)
    iconLabel.Font = Enum.Font.GothamMedium
    iconLabel.TextSize = 12
    iconLabel.TextWrapped = true
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = container

    -- Base do Switch
    local btnBase = Instance.new("TextButton")
    btnBase.Size = UDim2.new(0, 50, 0, 22)
    btnBase.Position = UDim2.new(0.5, 0, 0.6, 0)
    btnBase.AnchorPoint = Vector2.new(0.5, 0.5)
    btnBase.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Vermelho desligado
    btnBase.Text = ""
    btnBase.AutoButtonColor = false
    btnBase.Parent = container

    Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1.5
    btnStroke.Color = Color3.fromRGB(255, 145, 0)
    btnStroke.Transparency = 0.5
    btnStroke.Parent = btnBase

    -- Knob (Bolinha)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0.1, 0, 0.5, 0)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = btnBase
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Lógica de Clique
    local active = false
    btnBase.MouseButton1Click:Connect(function()
        active = not active
        
        local targetPos = active and UDim2.new(0.9, -18, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
        local targetColor = active and Color3.fromRGB(0, 160, 0) or Color3.fromRGB(150, 0, 0)

        TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = targetPos}):Play()
        TweenService:Create(btnBase, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()

        task.spawn(loadstringFunction)
    end)
end

