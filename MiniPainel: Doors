-- 4. FUNÇÃO DE TOGGLE OTIMIZADA
-- ==========================================
local loadedScripts = {} -- Tabela para rastrear scripts já baixados

local function CreateToggle(name, labelText, posX, saveKey, url)
    local container = Instance.new("Frame")
    container.Name = name .. "Container"
    container.Size = UDim2.new(0.3, 0, 0, 60)
    container.Position = UDim2.new(posX, 0, 0.65, 0)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.ZIndex = miniPainel.ZIndex + 1
    container.Parent = miniPainel

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 25)
    iconLabel.Text = labelText
    iconLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    iconLabel.Font = Enum.Font.GothamMedium
    iconLabel.TextSize = 11
    iconLabel.BackgroundTransparency = 1
    iconLabel.ZIndex = container.ZIndex + 1
    iconLabel.Parent = container

    local btnBase = Instance.new("TextButton")
    btnBase.Size = UDim2.new(0, 45, 0, 20)
    btnBase.Position = UDim2.new(0.5, 0, 0.7, 0)
    btnBase.AnchorPoint = Vector2.new(0.5, 0.5)
    btnBase.Text = ""
    btnBase.AutoButtonColor = false -- Controle manual do visual de clique
    btnBase.ZIndex = container.ZIndex + 2
    btnBase.Parent = container
    Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 2
    btnStroke.Parent = btnBase

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.ZIndex = btnBase.ZIndex + 1
    knob.Parent = btnBase
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Define falso por padrão se não existir
    if _G[saveKey] == nil then _G[saveKey] = false end

    local function UpdateVisual(instant)
        local active = _G[saveKey]
        local targetPos = active and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        local bgColor = active and Color3.fromRGB(130, 0, 0) or Color3.fromRGB(30, 30, 30) -- Vermelho escuro vs Cinza escuro
        local strokeColor = active and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(80, 80, 80)

        if instant then
            knob.Position = targetPos
            btnBase.BackgroundColor3 = bgColor
            btnStroke.Color = strokeColor
        else
            TweenService:Create(knob, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos}):Play()
            TweenService:Create(btnBase, TweenInfo.new(0.2), {BackgroundColor3 = bgColor}):Play()
            TweenService:Create(btnStroke, TweenInfo.new(0.2), {Color = strokeColor}):Play()
        end
    end

    UpdateVisual(true)

    btnBase.Activated:Connect(function()
        _G[saveKey] = not _G[saveKey]
        UpdateVisual(false)
        
        -- Efeito visual de clique no botão
        local clickTween = TweenService:Create(btnBase, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {Size = UDim2.new(0, 40, 0, 18)})
        clickTween:Play()

        -- Carrega o script da web apenas na primeira vez que for ativado
        if _G[saveKey] then
            if not loadedScripts[saveKey] then
                loadedScripts[saveKey] = true
                task.spawn(function() 
                    local success, err = pcall(function()
                        loadstring(game:HttpGet(url))() 
                    end)
                    if not success then
                        warn("Falha ao carregar script (" .. labelText .. "): " .. tostring(err))
                        loadedScripts[saveKey] = false -- Permite tentar de novo
                    end
                end)
            end
        end
    end)
end

