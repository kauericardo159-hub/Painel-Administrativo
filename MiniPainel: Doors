strokePreto.Color = Color3.fromRGB(0, 0, 0)
strokePreto.Transparency = 1
strokePreto.Parent = miniPainel

task.spawn(function()
    while miniPainel.Parent do
        local ti = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
