local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

-- 1. CONFIGURAÇÃO DE CONEXÃO OFICIAL
-- O link solicitado foi integrado para carregar a lógica do sistema automaticamente
local function carregarSistema()
    local sucesso, erro = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/kauericardo159-hub/Painel-Administrativo/refs/heads/main/View%20Player%20%26%20Bot"))()
    end)
    if not sucesso then warn("Falha ao conectar com o sistema de View: " .. tostring(erro)) end
end

-- 2. LOCALIZAÇÃO E LIMPEZA
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3", 5)
local painel = coreGui:WaitForChild("Painel")
local lista = painel:WaitForChild("ListaOpcoesContainer")

if lista:FindFirstChild("ViewControlCard") then
    lista.ViewControlCard:Destroy()
end

