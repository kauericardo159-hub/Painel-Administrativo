-- 4. FUNÇÃO DE CRIAÇÃO DE SWITCH (Toggle Estilizado)
local function CreateModernToggle(name, icon, labelText, posX)
    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(0, 140, 0, 60)
    holder.Position = UDim2.new(posX, 0, 0.65, 0)
    holder.AnchorPoint = Vector2.new(0.5, 0.5)
    holder.BackgroundTransparency = 1
    holder.Parent = card

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Text = icon .. " " .. labelText
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.BackgroundTransparency = 1
    label.Parent = holder

    -- Estrutura do Switch
    local bg = Instance.new("TextButton")
    bg.Size = UDim2.new(0, 55, 0, 24)
    bg.Position = UDim2.new(0.5, 0, 0.7, 0)
    bg.AnchorPoint = Vector2.new(0.5, 0.5)
    bg.BackgroundColor3 = Color3.fromRGB(150, 40, 40) -- Vermelho suave
    bg.Text = ""
    bg.AutoButtonColor = false
    bg.Parent = holder
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0.1, 0, 0.5, 0)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = bg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Lógica e Animação
    local active = false
    bg.MouseButton1Click:Connect(function()
        active = not active
        local tPos = active and UDim2.new(0.9, -18, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
        local tCol = active and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)

        TweenService:Create(knob, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Position = tPos}):Play()
        TweenService:Create(bg, TweenInfo.new(0.4), {BackgroundColor3 = tCol}):Play()

        -- Ativação Global para o Sistema Externo
        if name == "Player" then _G.ViewPlayerActive = active 
        else _G.ViewBotActive = active end
    end)
end

-- 5. EXECUÇÃO
CreateModernToggle("Player", "👤", "PLAYER", 0.3)
CreateModernToggle("Bot", "🤖", "BOT", 0.7)

-- Carregar a lógica do sistema solicitado
carregarSistema()

-- Animação de Entrada do Card
TweenService:Create(card, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {GroupTransparency = 0}):Play()
