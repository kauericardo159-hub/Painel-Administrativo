-- 4. FUNÇÃO PARA CRIAR BOTÕES TOGGLE ESTILOSOS
local function CreateToggle(name, labelText, posX)
    local container = Instance.new("Frame")
    container.Name = name .. "Container"
    container.Size = UDim2.new(0, 120, 0, 50)
    container.Position = UDim2.new(posX, 0, 0.6, 0)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.Parent = miniPainel

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Position = UDim2.new(0, 0, -0.4, 0)
    label.Text = labelText
    label.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.BackgroundTransparency = 1
    label.Parent = container

    -- Base do Switch
    local switchBase = Instance.new("TextButton")
    switchBase.Size = UDim2.new(0, 60, 0, 26)
    switchBase.Position = UDim2.new(0.5, 0, 0.5, 0)
    switchBase.AnchorPoint = Vector2.new(0.5, 0.5)
    switchBase.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Inicia Vermelho
    switchBase.Text = ""
    switchBase.AutoButtonColor = false
    switchBase.Parent = container

    Instance.new("UICorner", switchBase).CornerRadius = UDim.new(1, 0)

    -- Círculo do Switch (O botão que desliza)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0.1, 0, 0.5, 0)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = switchBase

    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Lógica de Animação
    local active = false
    switchBase.MouseButton1Click:Connect(function()
        active = not active
        local targetPos = active and UDim2.new(0.9, -20, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
        local targetColor = active and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(150, 0, 0)

        TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = targetPos}):Play()
        TweenService:Create(switchBase, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()

        -- CHAMADA DO SISTEMA EXTERNO
        if SISTEMA_URL ~= "SISTEMA_LINK_AQUI" then
            loadstring(game:HttpGet(SISTEMA_URL .. "?mode=" .. name .. "&state=" .. tostring(active)))()
        end
    end)
end

-- Criar os dois controles lado a lado
CreateToggle("PlayerView", "👤 Player", 0.3)
CreateToggle("BotView", "🤖 Bot", 0.7)

-- 5. ANIMAÇÃO DE ENTRADA NA LISTA
