local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE TOGGLE (LIGA/DESLIGA)
-- ==========================================
if _G.SystemViewBotActive then
    _G.SystemViewBotActive = false -- Desativa o loop de busca
    
    if _G.SystemViewBotConnection then
        _G.SystemViewBotConnection:Disconnect()
        _G.SystemViewBotConnection = nil
    end
    
    -- Limpeza profunda do Cache ao desativar
    if _G.BotCacheViewBot then
        for _, visualData in pairs(_G.BotCacheViewBot) do
            if visualData.Highlight then visualData.Highlight:Destroy() end
            if visualData.UI then visualData.UI:Destroy() end
        end
        table.clear(_G.BotCacheViewBot)
    end
    
    if _G.SystemViewBotFolder then
        _G.SystemViewBotFolder:Destroy()
        _G.SystemViewBotFolder = nil
    end
    
    print("[SYSTEM] View Bot: DESATIVADO E LIMPO")
    return
end

_G.SystemViewBotActive = true
print("[SYSTEM] View Bot: ATIVADO (Otimizado)")

-- ==========================================
-- CONFIGURAÇÕES
-- ==========================================
local MAX_DISTANCE = 400
local FADE_START = 150

-- Cores
local BOT_NAME_COLOR = "#FFFFFF"
local BOT_STROKE_COLOR = Color3.fromRGB(255, 0, 0)
local OUTLINE_COLOR = Color3.fromRGB(255, 0, 0)
local DIST_COLOR = "#C8C800"
local HP_COLOR = "#B40000"

-- Nomes de entidades que o script DEVE focar (Mesmo sem Humanoid)
local MONSTER_NAMES = {
    "rush", "ambush", "figure", "seek", "screech", "halt", "eyes",
    "angler", "pandemonium", "blitz", "chainsmoker", "pinkie", "froger",
    "ayuwoki", "rakoof", "monster", "killer", "bot", "enemy", "chaser"
}

-- Nomes de entidades que o script DEVE ignorar (Vendedores, NPCs)
local IGNORED_NAMES = {
    "npc", "vendor", "shop", "merchant", "dummy", "guide", "trader", "jeff", "el goblino", "bob", "sebastian"
}

-- Pasta Global
_G.SystemViewBotFolder = Instance.new("Folder")
_G.SystemViewBotFolder.Name = "ViewBotCache"
_G.SystemViewBotFolder.Parent = localPlayer:WaitForChild("PlayerGui")

-- Cache Global para facilitar a limpeza
_G.BotCacheViewBot = {}
local botCache = _G.BotCacheViewBot

-- ==========================================
-- FUNÇÕES AUXILIARES
-- ==========================================
local function createVisuals(model)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "BotOutline"
    hl.FillTransparency = 1
    hl.OutlineColor = OUTLINE_COLOR
    hl.OutlineTransparency = 0
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "BotInfo"
    bg.Size = UDim2.new(0, 200, 0, 45)
    bg.StudsOffset = Vector3.new(0, 2, 0)
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemViewBotFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = BOT_STROKE_COLOR
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    local statsLabel = Instance.new("TextLabel")
    statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.TextStrokeTransparency = 0.5
    statsLabel.RichText = true
    statsLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    data.StatsLabel = statsLabel
    data.Model = model -- Referência guardada
    
    return data
end

-- Função para verificar bots
local function isBot(model)
    if not model:IsA("Model") then return false end
    if Players:GetPlayerFromCharacter(model) then return false end
    if model == localPlayer.Character then return false end
    
    local nameLower = string.lower(model.Name)
    
    for _, ignored in ipairs(IGNORED_NAMES) do
        if string.find(nameLower, ignored) then return false end
    end
    
    for _, monster in ipairs(MONSTER_NAMES) do
        if string.find(nameLower, monster) then return true end
    end
    
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum then
        if hum.WalkSpeed == 0 or hum.MaxHealth > 99999 then return false end 
        return true
    end
    
    return false
end

-- ==========================================
-- THREAD 1: BUSCADOR DE BOTS (Lento para não dar Lag)
-- ==========================================
task.spawn(function()
    while _G.SystemViewBotActive do
        local descendants = workspace:GetDescendants()
        
        for i, obj in ipairs(descendants) do
            if not _G.SystemViewBotActive then break end
            
            -- Só checa se for um modelo e se ainda não estiver no cache
            if obj:IsA("Model") and not botCache[obj] then
                if isBot(obj) then
                    botCache[obj] = createVisuals(obj)
                end
            end
            
            -- Pausa a cada 500 itens verificados para evitar que o FPS caia
            if i % 500 == 0 then
                task.wait()
            end
        end
        
        task.wait(1.5) -- Espera 1.5 segundos antes de buscar de novo
    end
end)

-- ==========================================
-- THREAD 2: LOOP DE RENDERIZAÇÃO (Leve e Rápido)
-- ==========================================
_G.SystemViewBotConnection = RunService.RenderStepped:Connect(function()
    local myChar = localPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if not myHRP then return end

    -- Loop EXCLUSIVO no cache (Não procura no Workspace inteiro!)
    for botModel, vis in pairs(botCache) do
        
        -- Limpeza caso o bot seja deletado do jogo
        if not botModel or not botModel.Parent then
            vis.Highlight:Destroy()
            vis.UI:Destroy()
            botCache[botModel] = nil
            continue
        end

        local head = botModel:FindFirstChild("Head") 
            or botModel:FindFirstChild("HumanoidRootPart") 
            or botModel:FindFirstChild("Torso") 
            or botModel.PrimaryPart 
            or botModel:FindFirstChildWhichIsA("BasePart")
            
        local hum = botModel:FindFirstChildOfClass("Humanoid")
        
        local isAlive = true
        if hum then
            isAlive = hum.Health > 0
        end
        
        if head and isAlive then
            local dist = (myHRP.Position - head.Position).Magnitude
            
            if dist <= MAX_DISTANCE then
                local fade = math.clamp((dist - FADE_START) / (MAX_DISTANCE - FADE_START), 0, 1)
                
                vis.Highlight.Parent = botModel
                vis.Highlight.OutlineTransparency = fade
                
                vis.UI.Adornee = head
                vis.UI.Enabled = true
                
                local strokeFade = 0.5 + (fade * 0.5)
                vis.NameLabel.TextStrokeTransparency = fade
                vis.StatsLabel.TextStrokeTransparency = strokeFade
                vis.NameLabel.TextTransparency = fade
                vis.StatsLabel.TextTransparency = fade
                
                local hpText = hum and math.floor(hum.Health) or "???"
                
                vis.NameLabel.Text = string.format('<font color="%s">🤖: %s</font>', BOT_NAME_COLOR, botModel.Name)
                vis.StatsLabel.Text = string.format('<font color="%s">📏: %dm.</font> | <font color="%s">❤: %s</font>', DIST_COLOR, math.floor(dist), HP_COLOR, tostring(hpText))
            else
                vis.Highlight.Parent = nil
                vis.UI.Enabled = false
            end
        else
            vis.Highlight.Parent = nil
            vis.UI.Enabled = false
        end
    end
end)
