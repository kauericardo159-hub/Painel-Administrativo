local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE TOGGLE (LIGA/DESLIGA)
-- ==========================================
if _G.SystemViewBotConnection then
    _G.SystemViewBotConnection:Disconnect()
    _G.SystemViewBotConnection = nil
    
    -- Limpeza profunda do Cache ao desativar
    if _G.BotCacheView then
        for _, visualData in pairs(_G.BotCacheView) do
            if visualData.Highlight then visualData.Highlight:Destroy() end
            if visualData.UI then visualData.UI:Destroy() end
        end
        table.clear(_G.BotCacheView)
    end
    
    if _G.SystemViewBotFolder then
        _G.SystemViewBotFolder:Destroy()
        _G.SystemViewBotFolder = nil
    end
    
    print("[SYSTEM] View Bot: DESATIVADO E LIMPO")
    return
end

print("[SYSTEM] View Bot: ATIVADO")

-- ==========================================
-- CONFIGURAÇÕES
-- ==========================================
local MAX_DISTANCE = 400
local FADE_START = 150
local BOT_COLOR = Color3.fromRGB(255, 0, 0) -- Vermelho para Outline e Stroke

-- Pasta Global para armazenar as UIs
_G.SystemViewBotFolder = Instance.new("Folder")
_G.SystemViewBotFolder.Name = "ViewBotCache"
_G.SystemViewBotFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.BotCacheView = {}
local localCache = _G.BotCacheView

-- ==========================================
-- FUNÇÕES AUXILIARES
-- ==========================================

-- Cria os visuais apenas uma vez por bot detectado
local function createVisuals(botModel)
    local data = {}
    
    -- Outline (Highlight) Vermelho
    local hl = Instance.new("Highlight")
    hl.Name = "BotOutline"
    hl.FillTransparency = 1
    hl.OutlineColor = BOT_COLOR
    hl.Parent = botModel
    
    -- UI acima do bot (BillboardGui)
    local bg = Instance.new("BillboardGui")
    bg.Name = "BotInfo"
    bg.Size = UDim2.new(0, 200, 0, 45)
    bg.StudsOffset = Vector3.new(0, 3, 0) -- Ajustado para ficar bem acima
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemViewBotFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 16
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Nome Branco
    nameLabel.TextStrokeColor3 = BOT_COLOR -- Stroke Vermelho
    nameLabel.TextStrokeTransparency = 0 -- Stroke Ativo
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    
    return data
end

-- ==========================================
-- LOOP DE RENDERIZAÇÃO
-- ==========================================
_G.SystemViewBotConnection = RunService.RenderStepped:Connect(function()
    local myChar = localPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if not myHRP then return end
    
    -- Varrer o workspace em busca de objetos que parecem bots
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- Ignorar se for o player, se não for um modelo, ou se for algo de UI
        if obj:IsA("Model") and obj ~= myChar and not obj:IsDescendantOf(Players) then
            
            local hum = obj:FindFirstChildOfClass("Humanoid")
            local head = obj:FindFirstChild("Head") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso")
            
            -- Detectar bots com ou sem humanoid, desde que tenham uma "cabeça" ou torso
            if head and (hum or obj:FindFirstChild("HumanoidRootPart")) then
                
                local dist = (myHRP.Position - head.Position).Magnitude
                
                if dist <= MAX_DISTANCE then
                    if not localCache[obj] then
                        localCache[obj] = createVisuals(obj)
                    end
                    
                    local vis = localCache[obj]
                    local fade = math.clamp((dist - FADE_START) / (MAX_DISTANCE - FADE_START), 0, 1)
                    
                    -- Atualiza Outline com Fade
                    vis.Highlight.OutlineTransparency = fade
                    
                    -- Atualiza UI
                    vis.UI.Adornee = head
                    vis.UI.Enabled = true
                    
                    -- Aplica Transparência no Texto e no Stroke
                    local textFade = fade
                    local strokeFade = math.clamp(fade, 0, 0.5) -- Stroke um pouco mais visível
                    
                    vis.NameLabel.TextTransparency = textFade
                    vis.NameLabel.TextStrokeTransparency = strokeFade
                    
                    -- Nome do Bot (Pode ser o nome do modelo ou um nome amigável)
                    vis.NameLabel.Text = string.format('🤖: %s', obj.Name)
                else
                    -- Fora da distância
                    if localCache[obj] then
                        localCache[obj].Highlight.OutlineTransparency = 1
                        localCache[obj].UI.Enabled = false
                    end
                end
            end
        end
    end
    
    -- CORREÇÃO: Limpar cache de bots que foram destruídos no jogo
    for botModel, visualData in pairs(localCache) do
        if not botModel.Parent then
            if visualData.Highlight then visualData.Highlight:Destroy() end
            if visualData.UI then visualData.UI:Destroy() end
            localCache[botModel] = nil
        end
    end
end)
