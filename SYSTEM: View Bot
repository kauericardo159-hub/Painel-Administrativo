-- ==========================================
-- CONFIGURAÇÕES
-- ==========================================
local MAX_DISTANCE = 400
local FADE_START = 150
local UPDATE_RATE = 0.1 -- Frequência de atualização da lógica (em segundos)

-- Cores
local BOT_NAME_COLOR = "#FFFFFF" -- Nome Branco
local BOT_STROKE_COLOR = Color3.fromRGB(255, 0, 0) -- UIStroke Vermelho
local OUTLINE_COLOR = Color3.fromRGB(255, 0, 0) -- Outline Vermelho
local DIST_COLOR = "#C8C800" -- Amarelo um pouco escuro
local HP_COLOR = "#B40000"   -- Vermelho um pouco escuro

-- Pasta Global
_G.SystemViewBotFolder = Instance.new("Folder")
_G.SystemViewBotFolder.Name = "ViewBotCache"
_G.SystemViewBotFolder.Parent = localPlayer:WaitForChild("PlayerGui")

-- Cache Global para facilitar a limpeza
_G.BotCacheViewBot = {}
local botCache = _G.BotCacheViewBot

-- ==========================================
-- FUNÇÕES AUXILIARES
-- ==========================================
local function createVisuals(model)
    local data = {}
    
    -- Outline (Highlight) - Cor Vermelha
    local hl = Instance.new("Highlight")
    hl.Name = "BotOutline"
    hl.FillTransparency = 1
    hl.OutlineColor = OUTLINE_COLOR
    hl.OutlineTransparency = 0
    
    -- UI acima da cabeça (BillboardGui)
    local bg = Instance.new("BillboardGui")
    bg.Name = "BotInfo"
    bg.Size = UDim2.new(0, 200, 0, 45)
    bg.StudsOffset = Vector3.new(0, 2, 0)
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemViewBotFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Nome Branco
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = BOT_STROKE_COLOR -- UIStroke Vermelho
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    local statsLabel = Instance.new("TextLabel")
    statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.TextStrokeTransparency = 0.5
    statsLabel.RichText = true
    statsLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    data.StatsLabel = statsLabel
    
    return data
end

-- Função para verificar se um modelo é um Bot e não um Player
local function isBot(model)
    if not model:IsA("Model") then return false end
    if Players:GetPlayerFromCharacter(model) then return false end -- Não é player
    if not model:FindFirstChild("Humanoid") then return false end -- Tem humanoid
    if model == localPlayer.Character then return false end -- Não é o próprio player
    return true
end

