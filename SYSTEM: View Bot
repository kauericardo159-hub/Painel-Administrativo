    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = BOT_STROKE_COLOR -- UIStroke Vermelho
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    local statsLabel = Instance.new("TextLabel")
    statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.TextStrokeTransparency = 0.5
    statsLabel.RichText = true
    statsLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    data.StatsLabel = statsLabel
    
    return data
end

-- Função APRIMORADA para verificar bots
local function isBot(model)
    if not model:IsA("Model") then return false end
    if Players:GetPlayerFromCharacter(model) then return false end -- Não é player
    if model == localPlayer.Character then return false end -- Não é o próprio player
    
    local nameLower = string.lower(model.Name)
    
    -- 1. Verifica Blacklist (Ignora NPCs pacíficos pelo nome)
    for _, ignored in ipairs(IGNORED_NAMES) do
        if string.find(nameLower, ignored) then return false end
    end
    
    -- 2. Verifica Whitelist (Monstros conhecidos que podem não ter Humanoid)
    for _, monster in ipairs(MONSTER_NAMES) do
        if string.find(nameLower, monster) then return true end
    end
    
    -- 3. Verificaência Genérica de Inimigo (Tem Humanoid, mas se move e tem vida normal)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum then
        -- Se a velocidade for 0 ou tiver vida infinita, quase certeza que é um Vendor/NPC estático
        if hum.WalkSpeed == 0 or hum.MaxHealth > 99999 then return false end 
        return true
    end
    
    return false
end

