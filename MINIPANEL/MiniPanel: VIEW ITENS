local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

--[[ 
===========================================================
       ⚙ GERENCIADOR DO MINI-PAINEL ITENS V10 (ELITE) ⚙
===========================================================
]]

-- 1. CONEXÃO SEGURA COM O SISTEMA LÓGICO
if not _G.ViewItensSystemLoaded then
    task.spawn(pcall, function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/kauericardo159-hub/Painel-Administrativo/refs/heads/main/SYSTEM%3A%20View%20Itens"))()
        _G.ViewItensSystemLoaded = true
    end)
end

-- 2. LOCALIZAÇÃO E LIMPEZA
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3")
local painel = coreGui:WaitForChild("Panel")
local lista = painel:WaitForChild("ListaOpcoesContainer")

if lista:FindFirstChild("ViewItensCard") then
    lista.ViewItensCard:Destroy()
end

-- 3. CRIAÇÃO DO MINI-PAINEL (Design Premium V10)
local miniPainel = Instance.new("Frame")
miniPainel.Name = "ViewItensCard"
miniPainel.Size = UDim2.new(0.96, 0, 0, 100) 
miniPainel.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
miniPainel.BackgroundTransparency = 0.4 
miniPainel.BorderSizePixel = 0
miniPainel.ZIndex = lista.ZIndex + 10
miniPainel.Parent = lista

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 14)
corner.Parent = miniPainel

local stroke = Instance.new("UIStroke")
stroke.Thickness = 1.5
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Transparency = 0.7
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
stroke.Parent = miniPainel

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.Position = UDim2.new(0, 0, 0, 5)
title.BackgroundTransparency = 1
title.Text = "INVENTORY VIEWER"
title.TextColor3 = Color3.fromRGB(200, 200, 200)
title.Font = Enum.Font.GothamBold
title.TextSize = 12
title.TextTransparency = 0.3
title.ZIndex = miniPainel.ZIndex + 1
title.Parent = miniPainel

-- 4. ESTRUTURA DO TOGGLE CENTRALIZADO
local container = Instance.new("Frame")
container.Name = "ToggleContainer"
container.Size = UDim2.new(0.6, 0, 0, 50)
container.Position = UDim2.new(0.5, 0, 0.65, 0)
container.AnchorPoint = Vector2.new(0.5, 0.5)
container.BackgroundTransparency = 1
container.ZIndex = miniPainel.ZIndex + 1
container.Parent = miniPainel

local iconLabel = Instance.new("TextLabel")
iconLabel.Size = UDim2.new(1, 0, 0, 20)
iconLabel.Position = UDim2.new(0, 0, 0, 0)
iconLabel.Text = "📦 View Itens"
iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
iconLabel.Font = Enum.Font.GothamMedium
iconLabel.TextSize = 14
iconLabel.BackgroundTransparency = 1
iconLabel.ZIndex = miniPainel.ZIndex + 2
iconLabel.Parent = container

local colorInactiveBase = Color3.fromRGB(40, 15, 15)
local colorInactiveStroke = Color3.fromRGB(200, 50, 50)
local colorActiveBase = Color3.fromRGB(15, 40, 25)
local colorActiveStroke = Color3.fromRGB(50, 200, 100)

local btnBase = Instance.new("TextButton")
btnBase.Size = UDim2.new(0, 55, 0, 26)
btnBase.Position = UDim2.new(0.5, 0, 0.8, 0)
btnBase.AnchorPoint = Vector2.new(0.5, 0.5)
btnBase.BackgroundColor3 = _G.ViewItensActive and colorActiveBase or colorInactiveBase
btnBase.Text = ""
btnBase.AutoButtonColor = false
btnBase.ZIndex = miniPainel.ZIndex + 2
btnBase.Parent = container

Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)

local btnStroke = Instance.new("UIStroke")
btnStroke.Thickness = 1.5
btnStroke.Color = _G.ViewItensActive and colorActiveStroke or colorInactiveStroke
btnStroke.Parent = btnBase

local knob = Instance.new("Frame")
knob.Size = UDim2.new(0, 20, 0, 20)
knob.Position = _G.ViewItensActive and UDim2.new(0.9, -20, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
knob.AnchorPoint = Vector2.new(0, 0.5)
knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
knob.ZIndex = btnBase.ZIndex + 1
knob.Parent = btnBase
Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

-- 5. LÓGICA DE CLIQUE (Com Notificação Integrada)
btnBase.MouseButton1Click:Connect(function()
    _G.ViewItensActive = not _G.ViewItensActive
    local ativo = _G.ViewItensActive
    
    -- Disparar Notificação Elite
    if _G.NotifyElite then
        local statusTxt = ativo and "ATIVADO" or "DESATIVADO"
        _G.NotifyElite("INVENTORY SYSTEM", "O rastreio de itens foi " .. statusTxt .. "!", ativo)
    end
    
    local targetPos = ativo and UDim2.new(0.9, -20, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
    local targetBaseColor = ativo and colorActiveBase or colorInactiveBase
    local targetStrokeColor = ativo and colorActiveStroke or colorInactiveStroke

    TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = targetPos}):Play()
    TweenService:Create(btnBase, TweenInfo.new(0.3), {BackgroundColor3 = targetBaseColor}):Play()
    TweenService:Create(btnStroke, TweenInfo.new(0.3), {Color = targetStrokeColor}):Play()
end)

-- 6. ANIMAÇÃO DE ENTRADA
local function animateEntry()
    local originalPos = UDim2.new(0.02, 0, 0, 0)
    miniPainel.Position = UDim2.new(1.5, 0, 0, 0)
    miniPainel.BackgroundTransparency = 1
    stroke.Transparency = 1
    
    task.wait(0.6)
    TweenService:Create(miniPainel, TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = originalPos,
        BackgroundTransparency = 0.4
    }):Play()
    TweenService:Create(stroke, TweenInfo.new(0.8), {Transparency = 0.7}):Play()
end

animateEntry()

print("✅ MiniPainel Itens V10: Agora com Notificações Elite!")
