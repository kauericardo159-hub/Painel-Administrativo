local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES
local MAX_DISTANCE = 100
local SCAN_RATE = 1 -- Aumentado para 1s (O escaneamento não congela mais a tela)
local UPDATE_RATE = 0.1

_G.ViewItensActive = _G.ViewItensActive or false

local trackedItems = {} -- Cache de itens válidos e seus handles
local activeHighlights = {}
local activeUIs = {}

-- Limpeza rápida e segura de um item específico
local function clearVisuals(obj)
    if activeHighlights[obj] then 
        activeHighlights[obj]:Destroy() 
        activeHighlights[obj] = nil 
    end
    if activeUIs[obj] then 
        activeUIs[obj]:Destroy() 
        activeUIs[obj] = nil 
    end
    trackedItems[obj] = nil
end

-- Limpeza total (ao desativar)
local function forceFullCleanup()
    for obj, _ in pairs(activeHighlights) do clearVisuals(obj) end
    for obj, _ in pairs(activeUIs) do clearVisuals(obj) end
    table.clear(trackedItems)
end

-- Validação e captura do Handle (Otimizado)
local function validateAndGetHandle(obj)
    if not obj or not obj.Parent then return nil end
    if not (obj:IsA("Tool") or (obj:IsA("Model") and obj:FindFirstChild("Handle"))) then return nil end
    
    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    if not handle or handle.Transparency > 0.5 then return nil end

    -- Verifica se o item está equipado (Ignora ferramentas na mão)
    local ancestorModel = obj:FindFirstAncestorWhichIsA("Model")
    if ancestorModel and ancestorModel:FindFirstChildOfClass("Humanoid") then return nil end

    -- Filtro de nome
    local name = obj.Name:lower()
    if string.find(name, "door") or string.find(name, "porta") or string.find(name, "gate") then return nil end

    return handle
end

-- LOOP 1: Varredura de Itens (Parcelada para não causar Queda de FPS)
task.spawn(function()
    while true do
        if _G.ViewItensActive then
            local descendants = workspace:GetDescendants()
            
            for i = 1, #descendants do
                local obj = descendants[i]
                
                -- O SEGREDO DO FPS: Pausa o loop a cada 500 itens para o jogo respirar
                if i % 500 == 0 then task.wait() end
                
                -- Se o jogador desativar o script no meio da varredura, interrompe
                if not _G.ViewItensActive then break end 
                
                local handle = validateAndGetHandle(obj)
                if handle then
                    trackedItems[obj] = handle
                else
                    -- Se o item deixou de ser válido (ex: alguém pegou), limpa os visuais
                    if trackedItems[obj] then clearVisuals(obj) end
                end
            end
        end
        task.wait(SCAN_RATE)
    end
end)

-- LOOP 2: Atualização de Distância e UIs (Respeitando os 0.1 segundos)
task.spawn(function()
    while true do
        if not _G.ViewItensActive then
            if next(activeHighlights) or next(activeUIs) then forceFullCleanup() end
            task.wait(0.5) -- Espera em modo econômico enquanto desativado
            continue
        end

        local char = localPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hrp then
            local hrpPos = hrp.Position
            
            -- Itera APENAS sobre os itens já filtrados, não o workspace todo
            for obj, handle in pairs(trackedItems) do
                -- Segurança contra itens deletados de repente
                if not obj.Parent or not handle.Parent then
                    clearVisuals(obj)
                    continue
                end

                local dist = (hrpPos - handle.Position).Magnitude
                
                if dist <= MAX_DISTANCE then
                    -- Lógica da UI (Cria apenas se não existir)
                    local ui = activeUIs[obj]
                    if not ui then
                        ui = Instance.new("BillboardGui")
                        ui.Name = "ItemViewUI"
                        ui.Size = UDim2.new(0, 150, 0, 40)
                        ui.StudsOffset = Vector3.new(0, 2, 0)
                        ui.AlwaysOnTop = true
                        ui.LightInfluence = 0
                        
                        local label = Instance.new("TextLabel")
                        label.Size = UDim2.new(1, 0, 1, 0)
                        label.BackgroundTransparency = 1
                        label.Font = Enum.Font.GothamBold
                        label.TextColor3 = Color3.fromRGB(255, 120, 0)
                        label.TextSize = 13
                        label.TextStrokeTransparency = 0.5
                        label.RichText = true
                        label.Parent = ui
                        
                        ui.Parent = handle
                        activeUIs[obj] = ui
                    end
                    ui.Enabled = true
                    ui.TextLabel.Text = string.format("📦 %s\n<font color='rgb(200,200,0)'>📏 %dM.</font>", obj.Name, math.floor(dist))
                    
                    -- Lógica do Highlight (Evita estourar o limite de 31 do Roblox)
                    if not activeHighlights[obj] then
                        local hl = Instance.new("Highlight")
                        hl.Name = "ItemHighlight"
                        hl.FillTransparency = 1
                        hl.OutlineColor = Color3.fromRGB(255, 120, 0)
                        hl.Parent = obj
                        activeHighlights[obj] = hl
                    end
                    activeHighlights[obj].Enabled = true
                else
                    -- Longe demais: Apenas desativa para poupar processamento
                    if activeUIs[obj] then activeUIs[obj].Enabled = false end
                    if activeHighlights[obj] then activeHighlights[obj].Enabled = false end
                end
            end
        end
        
        task.wait(UPDATE_RATE) -- Agora sim executa estritamente a cada 0.1s
    end
end)
