_G.SystemViewBotActive = true
print("[SYSTEM] View Bot: ATIVADO (Detecção em Tempo Real)")

-- ==========================================
-- CONFIGURAÇÕES
-- ==========================================
local MAX_DISTANCE = 450
local FADE_START = 300

-- Cores
local BOT_NAME_COLOR = "#FFFFFF"
local BOT_STROKE_COLOR = Color3.fromRGB(255, 0, 0)
local OUTLINE_COLOR = Color3.fromRGB(255, 0, 0)
local DIST_COLOR = "#C8C800"
local HP_COLOR = "#B40000"

-- Nomes focados (detecta até se for apenas um "Part" solto)
local MONSTER_NAMES = {
    "rush", "ambush", "figure", "seek", "screech", "halt", "eyes",
    "angler", "pandemonium", "blitz", "chainsmoker", "pinkie", "froger",
    "ayuwoki", "rakoof", "monster", "killer", "bot", "enemy", "chaser"
}

-- NPCs ignorados (Vendedores, guias, dummies)
local IGNORED_NAMES = {
    "npc", "vendor", "shop", "merchant", "dummy", "guide", "trader", 
    "jeff", "el goblino", "bob", "sebastian", "guidance"
}

_G.SystemViewBotFolder = Instance.new("Folder")
_G.SystemViewBotFolder.Name = "ViewBotCache"
_G.SystemViewBotFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.BotCacheViewBot = {}
local botCache = _G.BotCacheViewBot

-- ==========================================
-- FUNÇÕES AUXILIARES
-- ==========================================
local function createVisuals(entity)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "BotOutline"
    hl.FillTransparency = 1
    hl.OutlineColor = OUTLINE_COLOR
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "BotInfo"
    bg.Size = UDim2.new(0, 200, 0, 45)
    bg.StudsOffset = Vector3.new(0, 2, 0)
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemViewBotFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = BOT_STROKE_COLOR
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    local statsLabel = Instance.new("TextLabel")
    statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.TextStrokeTransparency = 0.5
    statsLabel.RichText = true
    statsLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    data.StatsLabel = statsLabel
    
    return data
end

local function isBot(obj)
    -- Ignora o jogador atual e outros jogadores
    if Players:GetPlayerFromCharacter(obj) or obj == localPlayer.Character then return false end
    
    local nameLower = string.lower(obj.Name)
    
    -- Ignora NPCs pacíficos
    for _, ignored in ipairs(IGNORED_NAMES) do
        if string.find(nameLower, ignored) then return false end
    end
    
    -- Prioridade 1: É um monstro da lista? (Aceita Models ou Parts)
    for _, monster in ipairs(MONSTER_NAMES) do
        if string.find(nameLower, monster) then return true end
    end
    
    -- Prioridade 2: É um Model genérico com Humanoid vivo?
    if obj:IsA("Model") then
        local hum = obj:FindFirstChildOfClass("Humanoid")
        if hum then
            -- Ignora "Lojistas" ou estruturas invencíveis que usam Humanoid
            if hum.WalkSpeed == 0 or hum.MaxHealth > 99990 then return false end 
            return true
        end
    end
    
    return false
end

local function checkAndAddEntity(obj)
    if (obj:IsA("Model") or obj:IsA("BasePart")) and not botCache[obj] then
        if isBot(obj) then
            botCache[obj] = createVisuals(obj)
        end
    end
end

-- ==========================================
-- THREAD 1: DETECÇÃO EM TEMPO REAL E INICIAL
-- ==========================================

-- 1. Varredura inicial rápida no que já existe no mapa
task.spawn(function()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if not _G.SystemViewBotActive then break end
        checkAndAddEntity(obj)
    end
end)

-- 2. Escuta ativa: Detecta IMEDIATAMENTE quando algo novo spawna
_G.SystemViewBotAddedConn = workspace.DescendantAdded:Connect(function(descendant)
    if not _G.SystemViewBotActive then return end
    
    -- Usamos um pequeno delay para dar tempo do jogo carregar o Humanoid/Partes dentro do Model
    task.delay(0.3, function()
        if descendant and descendant.Parent then
            checkAndAddEntity(descendant)
        end
    end)
end)

-- ==========================================
-- THREAD 2: LOOP DE RENDERIZAÇÃO
-- ==========================================
_G.SystemViewBotConnection = RunService.RenderStepped:Connect(function()
    local myChar = localPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if not myHRP then return end

    for botEntity, vis in pairs(botCache) do
        
        -- Limpeza automática se a entidade foi deletada
        if not botEntity or not botEntity.Parent then
            vis.Highlight:Destroy()
            vis.UI:Destroy()
            botCache[botEntity] = nil
            continue
        end

        -- Tenta achar a melhor parte para focar, seja um Model ou um BasePart solto
        local head = botEntity:IsA("BasePart") and botEntity
            or botEntity:FindFirstChild("Head") 
            or botEntity:FindFirstChild("HumanoidRootPart") 
            or botEntity.PrimaryPart 
            or botEntity:FindFirstChildWhichIsA("BasePart")
            
        local hum = botEntity:FindFirstChildOfClass("Humanoid")
        
        -- Só oculta se tiver um Humanoid morto (se for um objeto solto sem vida, continua mostrando)
        local isAlive = hum and (hum.Health > 0) or (not hum)
        
        if head and isAlive then
            local dist = (myHRP.Position - head.Position).Magnitude
            
            if dist <= MAX_DISTANCE then
                local fade = math.clamp((dist - FADE_START) / (MAX_DISTANCE - FADE_START), 0, 1)
                
                vis.Highlight.Parent = botEntity
                vis.Highlight.OutlineTransparency = fade
                
                vis.UI.Adornee = head
                vis.UI.Enabled = true
                
                local strokeFade = 0.5 + (fade * 0.5)
                vis.NameLabel.TextStrokeTransparency = fade
                vis.StatsLabel.TextStrokeTransparency = strokeFade
                vis.NameLabel.TextTransparency = fade
                vis.StatsLabel.TextTransparency = fade
                
                local hpText = hum and math.floor(hum.Health) or "N/A"
                
                vis.NameLabel.Text = string.format('<font color="%s">👾: %s</font>', BOT_NAME_COLOR, botEntity.Name)
                vis.StatsLabel.Text = string.format('<font color="%s">📏 %dm</font> | <font color="%s">❤ %s</font>', DIST_COLOR, math.floor(dist), HP_COLOR, tostring(hpText))
            else
                vis.Highlight.Parent = nil
                vis.UI.Enabled = false
            end
        else
            vis.Highlight.Parent = nil
            vis.UI.Enabled = false
        end
    end
end)
