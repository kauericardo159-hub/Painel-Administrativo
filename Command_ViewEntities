local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- [CONFIGURAÇÕES]
local DISTANCIA_MAXIMA = 350
local ESP_PLAYERS_ATIVO = false
local ESP_BOTS_ATIVO = false
local NOME_COMANDO = "View Entity System"

-- [LOCALIZAÇÃO]
local panelGui = playerGui:WaitForChild("MainPanel_ScreenGui")
local mainFrame = panelGui:WaitForChild("MainFrame")
local listFrame = mainFrame:WaitForChild("CommandList")

if listFrame:FindFirstChild(NOME_COMANDO) then listFrame[NOME_COMANDO]:Destroy() end

-- [CONTAINER PRINCIPAL]
local container = Instance.new("Frame")
container.Name = NOME_COMANDO
container.Size = UDim2.new(0.94, 0, 0, 80)
container.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
container.Parent = listFrame

Instance.new("UICorner", container).CornerRadius = UDim.new(0, 10)
local strokeMain = Instance.new("UIStroke", container)
strokeMain.Color = Color3.fromRGB(45, 45, 50)
strokeMain.Thickness = 2

-- Título Central
local mainTitle = Instance.new("TextLabel")
mainTitle.Size = UDim2.new(1, 0, 0, 25)
mainTitle.BackgroundTransparency = 1
mainTitle.Text = "VIEW SYSTEM"
mainTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
mainTitle.Font = Enum.Font.GothamBold
mainTitle.TextSize = 12
mainTitle.Parent = container

-- [FUNÇÃO: CRIAR SWITCH ESTILIZADO]
local function CreateSwitch(nome, pos, icon)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.45, 0, 0, 45)
    frame.Position = pos
    frame.BackgroundTransparency = 1
    frame.Parent = container

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Text = icon .. " " .. nome
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 13
    label.BackgroundTransparency = 1
    label.Parent = frame

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 40, 0, 20)
    bg.Position = UDim2.new(0.5, -20, 0.5, 0)
    bg.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    bg.Parent = frame
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", bg).Color = Color3.fromRGB(255, 255, 255)

    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 14, 0, 14)
    circle.Position = UDim2.new(0.1, 0, 0.5, -7)
    circle.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    circle.Parent = bg
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    return bg, circle, btn
end

local playerBg, playerCircle, playerBtn = CreateSwitch("PLAYER", UDim2.new(0.03, 0, 0.35, 0), "👤")
local botBg, botCircle, botBtn = CreateSwitch("BOT", UDim2.new(0.52, 0, 0.35, 0), "🤖")

-- [SISTEMA DE NOTIFICAÇÃO ESTILIZADO]
local function Notify(msg, cor)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, 260, 0, 50)
    card.Position = UDim2.new(1, 20, 0.85, 0) -- Lado direito fora
    card.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    card.Parent = panelGui
    
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)
    local s = Instance.new("UIStroke", card)
    s.Color = cor s.Thickness = 2

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.Text = msg
    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 13
    txt.BackgroundTransparency = 1
    txt.Parent = card

    card:TweenPosition(UDim2.new(1, -280, 0.85, 0), "Out", "Quart", 0.5)
    task.wait(3)
    card:TweenPosition(UDim2.new(1, 20, 0.85, 0), "In", "Quart", 0.5)
    game:GetService("Debris"):AddItem(card, 0.6)
end

-- [LÓGICA DE ANIMAÇÃO]
local function ToggleVisual(ativo, bg, circle)
    if ativo then
        TweenService:Create(circle, TweenInfo.new(0.3), {Position = UDim2.new(0.6, 0, 0.5, -7), BackgroundColor3 = Color3.fromRGB(80, 255, 80)}):Play()
        TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(30, 60, 30)}):Play()
    else
        TweenService:Create(circle, TweenInfo.new(0.3), {Position = UDim2.new(0.1, 0, 0.5, -7), BackgroundColor3 = Color3.fromRGB(255, 80, 80)}):Play()
        TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 55)}):Play()
    end
end

-- [LÓGICA ESP]
local espFolder = Instance.new("Folder", workspace)
espFolder.Name = "V4_ESP_Storage"

local function UpdateESP()
    espFolder:ClearAllChildren()
    if not ESP_PLAYERS_ATIVO and not ESP_BOTS_ATIVO then return end

    for _, target in ipairs(workspace:GetDescendants()) do
        local hum = target:FindFirstChildOfClass("Humanoid")
        local root = target:FindFirstChild("HumanoidRootPart")
        
        if hum and root and target ~= player.Character and hum.Health > 0 then
            local dist = (player.Character.HumanoidRootPart.Position - root.Position).Magnitude
            if dist > DISTANCIA_MAXIMA then continue end

            local isPlr = Players:GetPlayerFromCharacter(target)
            if (isPlr and not ESP_PLAYERS_ATIVO) or (not isPlr and not ESP_BOTS_ATIVO) then continue end

            local color = isPlr and (isPlr.TeamColor.Color) or Color3.fromRGB(255, 50, 50)
            local icon = isPlr and "👤" or "🤖"

            local hl = Instance.new("Highlight", espFolder)
            hl.Adornee = target
            hl.FillTransparency = 1
            hl.OutlineColor = color

            local bb = Instance.new("BillboardGui", espFolder)
            bb.Size = UDim2.new(0, 200, 0, 50)
            bb.Adornee = target:FindFirstChild("Head") or root
            bb.AlwaysOnTop = true
            bb.ExtentsOffset = Vector3.new(0, 3, 0)

            local l = Instance.new("TextLabel", bb)
            l.Size = UDim2.new(1, 0, 1, 0)
            l.BackgroundTransparency = 1
            l.TextColor3 = color
            l.Font = Enum.Font.GothamBold
            l.TextSize = 13
            l.Text = string.format("%s: %s\n📏 %dM | ❤ %d", icon, target.Name, dist, hum.Health)
        end
    end
end

-- Loop
task.spawn(function()
    while task.wait(0.5) do UpdateESP() end
end)

-- Cliques
playerBtn.MouseButton1Click:Connect(function()
    ESP_PLAYERS_ATIVO = not ESP_PLAYERS_ATIVO
    ToggleVisual(ESP_PLAYERS_ATIVO, playerBg, playerCircle)
    Notify(ESP_PLAYERS_ATIVO and "ESP PLAYERS: ATIVO" or "ESP PLAYERS: INATIVO", ESP_PLAYERS_ATIVO and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80))
end)

botBtn.MouseButton1Click:Connect(function()
    ESP_BOTS_ATIVO = not ESP_BOTS_ATIVO
    ToggleVisual(ESP_BOTS_ATIVO, botBg, botCircle)
    Notify(ESP_BOTS_ATIVO and "ESP BOTS: ATIVO" or "ESP BOTS: INATIVO", ESP_BOTS_ATIVO and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80))
end)
