-- [NOVO SISTEMA DE NOTIFICAÇÃO (TOAST MODERNO)]
local function ModernNotify(estado, cor)
    local toast = Instance.new("Frame")
    toast.Size = UDim2.new(0, 250, 0, 40)
    toast.Position = UDim2.new(0.5, -125, 0, -50) -- Começa fora do ecrã (topo)
    toast.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    toast.Parent = panelGui
    
    Instance.new("UICorner", toast).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", toast)
    stroke.Color = cor
    stroke.Thickness = 2
    
    local msg = Instance.new("TextLabel")
    msg.Size = UDim2.new(1, 0, 1, 0)
    msg.BackgroundTransparency = 1
    msg.Text = NOME_COMANDO .. " [" .. estado .. "]"
    msg.TextColor3 = Color3.fromRGB(255, 255, 255)
    msg.Font = Enum.Font.GothamBold
    msg.TextSize = 14
    msg.Parent = toast
    
    -- Animação de descida e desvanecimento
    toast:TweenPosition(UDim2.new(0.5, -125, 0.1, 0), "Out", "Back", 0.5)
    task.wait(2.5)
    
    local fadeOut = TweenService:Create(toast, TweenInfo.new(0.5), {BackgroundTransparency = 1})
    local fadeText = TweenService:Create(msg, TweenInfo.new(0.5), {TextTransparency = 1})
    local fadeStroke = TweenService:Create(stroke, TweenInfo.new(0.5), {Transparency = 1})
    
    fadeOut:Play() fadeText:Play() fadeStroke:Play()
    game:GetService("Debris"):AddItem(toast, 0.6)
end

-- [LÓGICA DO ESP: PLAYERS E BOTS]
local espFolder = Instance.new("Folder", workspace)
espFolder.Name = "EntityESP_Storage"

local function UpdateESP()
    espFolder:ClearAllChildren()
    if not ESTADO_ATIVO then return end
    
    local charLocal = player.Character
    local rootLocal = charLocal and charLocal:FindFirstChild("HumanoidRootPart")
    if not rootLocal then return end

    for _, target in ipairs(workspace:GetDescendants()) do
        local hum = target:FindFirstChildOfClass("Humanoid")
        local root = target:FindFirstChild("HumanoidRootPart")
        
        if hum and root and target ~= charLocal and hum.Health > 0 then
            local dist = (rootLocal.Position - root.Position).Magnitude
            
            -- Limite de Distância para evitar lentidão no jogo
            if dist <= DISTANCIA_MAXIMA then
                local isPlayer = Players:GetPlayerFromCharacter(target)
                
                -- Configuração dinâmica das cores e ícones
                local icon = isPlayer and "👤" or "🤖"
                local baseColor = isPlayer and (isPlayer.TeamColor and isPlayer.TeamColor.Color or Color3.fromRGB(255, 255, 255)) or Color3.fromRGB(255, 50, 50)
                
                -- 1. Outline (Highlight)
                local highlight = Instance.new("Highlight", espFolder)
                highlight.Adornee = target
                highlight.FillTransparency = 1 -- Apenas as bordas
                highlight.OutlineColor = baseColor
                highlight.OutlineTransparency = 0
                
                -- 2. Informações Visuais (Billboard)
                local billboard = Instance.new("BillboardGui", espFolder)
                billboard.Size = UDim2.new(0, 200, 0, 50)
                billboard.Adornee = target:FindFirstChild("Head") or root
                billboard.AlwaysOnTop = true
                billboard.ExtentsOffset = Vector3.new(0, 3, 0)
                
                local infoLabel = Instance.new("TextLabel", billboard)
                infoLabel.Size = UDim2.new(1, 0, 1, 0)
                infoLabel.BackgroundTransparency = 1
                infoLabel.TextColor3 = baseColor
                infoLabel.TextStrokeTransparency = 0.2
                infoLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                infoLabel.Font = Enum.Font.GothamBold
                infoLabel.TextSize = 13
                
                -- Texto Formatado (Ícone, Metros e Vida)
                local vida = math.floor(hum.Health)
                local distArredondada = math.floor(dist)
                infoLabel.Text = string.format("%s: %s\n📏 %d Metros | ❤ %d Vida", icon, target.Name, distArredondada, vida)
            end
        end
    end
end

-- [LOOP OTIMIZADO DE ATUALIZAÇÃO]
task.spawn(function()
    while task.wait(0.5) do
        if ESTADO_ATIVO then
            UpdateESP()
        end
    end
end)

-- [EVENTO DO BOTÃO]
clickRegion.MouseButton1Click:Connect(function()
    ESTADO_ATIVO = not ESTADO_ATIVO
    
    if ESTADO_ATIVO then
        statusLabel.Text = "( Ativo )"
        statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
        ModernNotify("ATIVADO", Color3.fromRGB(80, 255, 80))
    else
        statusLabel.Text = "( Inativo )"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        espFolder:ClearAllChildren()
        ModernNotify("DESATIVADO", Color3.fromRGB(255, 80, 80))
    end
end)
