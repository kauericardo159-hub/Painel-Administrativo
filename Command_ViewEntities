local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- [CONFIGURAÇÕES GERAIS]
local DISTANCIA_MAXIMA = 350
local PLAYER_ATIVO = false
local BOT_ATIVO = false
local NOME_COMANDO = "ViewEntities_Container"

-- [LOCALIZAÇÃO DA LISTA NO PAINEL]
local panelGui = playerGui:WaitForChild("MainPanel_ScreenGui")
local mainFrame = panelGui:WaitForChild("MainFrame")
local listFrame = mainFrame:WaitForChild("CommandList")

-- [LIMPEZA DE DUPLICATAS]
if listFrame:FindFirstChild(NOME_COMANDO) then
    listFrame[NOME_COMANDO]:Destroy()
end

-- ==========================================================
-- 1. CRIAÇÃO DA INTERFACE (BASEADA NA NOVA IMAGEM)
-- ==========================================================
local cmdContainer = Instance.new("Frame")
cmdContainer.Name = NOME_COMANDO
cmdContainer.Size = UDim2.new(0.95, 0, 0, 60)
cmdContainer.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
