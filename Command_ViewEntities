-- [FUNÇÃO: CRIAR SWITCH V7]
local function CreateSwitch(nome, pos, icon)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.48, 0, 0, 50)
    frame.Position = pos
    frame.BackgroundTransparency = 1
    frame.Parent = container

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Text = icon .. " " .. nome
    label.TextColor3 = Color3.fromRGB(180, 180, 185)
    label.Font = Enum.Font.JetBrainsMono -- Fonte Hacker/Code
    label.TextSize = 11
    label.BackgroundTransparency = 1
    label.Parent = frame

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 42, 0, 22)
    bg.Position = UDim2.new(0.5, -21, 0.5, 5)
    bg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    bg.Parent = frame
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    local s = Instance.new("UIStroke", bg)
    s.Color = Color3.fromRGB(80, 80, 85)
    s.Thickness = 1

    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 16, 0, 16)
    circle.Position = UDim2.new(0.1, 0, 0.5, -8)
    circle.BackgroundColor3 = Color3.fromRGB(255, 100, 100) -- Vermelho desativado
    circle.Parent = bg
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    return bg, circle, btn
end

local playerBg, playerCircle, playerBtn = CreateSwitch("PLAYERS", UDim2.new(0.01, 0, 0.3, 0), "👤")
local botBg, botCircle, botBtn = CreateSwitch("BOTS", UDim2.new(0.51, 0, 0.3, 0), "🤖")

