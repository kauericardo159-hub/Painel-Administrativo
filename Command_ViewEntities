-- [FUNÇÃO PARA CRIAR OS INTERRUPTORES (TOGGLES)]
local function CriarToggle(nome, icone, posX)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.3, 0, 1, 0)
    container.Position = UDim2.new(posX, 0, 0, 0)
    container.BackgroundTransparency = 1
    container.Parent = cmdBtn

    -- Título (Ex: 👤 Player:)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0.4, 0)
    label.Position = UDim2.new(0, 0, 0.1, 0)
    label.BackgroundTransparency = 1
    label.Text = icone .. " " .. nome .. ":"
    label.TextColor3 = Color3.fromRGB(255, 30, 30)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.Parent = container

    -- Fundo do Toggle (A caixinha)
    local toggleBg = Instance.new("Frame")
    toggleBg.Size = UDim2.new(0, 50, 0, 22)
    toggleBg.Position = UDim2.new(0.5, -25, 0.55, 0)
    toggleBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    toggleBg.Parent = container
    
    local stroke = Instance.new("UIStroke", toggleBg)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 1.5

    -- Linha Divisória no meio
    local divisor = Instance.new("Frame")
    divisor.Size = UDim2.new(0, 2, 0.8, 0)
    divisor.Position = UDim2.new(0.5, -1, 0.1, 0)
    divisor.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
    divisor.BorderSizePixel = 0
    divisor.Parent = toggleBg

    -- Círculo do Toggle
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 16, 0, 16)
    circle.Position = UDim2.new(0, 3, 0.5, -8) -- Posição Inativa (Esquerda)
    circle.BackgroundColor3 = Color3.fromRGB(150, 150, 150) -- Cinza
    circle.Parent = toggleBg
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    -- Botão invisível para clicar
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = toggleBg

    return circle, btn
end

-- Criando os dois Toggles
local playerCircle, playerBtn = CriarToggle("Player", "👤", 0.3)
local botCircle, botBtn = CriarToggle("BOT", "🤖", 0.65)

-- [ANIMAÇÃO DE ATIVAR/DESATIVAR]
local function AnimarToggle(circle, ativo)
    local endPos = ativo and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    local endColor = ativo and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(150, 150, 150)

    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(circle, tweenInfo, {Position = endPos, BackgroundColor3 = endColor}):Play()
end

-- [LÓGICA DO ESP]
local espFolder = Instance.new("Folder", workspace)
espFolder.Name = "EntityESP_Storage"

local function UpdateESP()
    espFolder:ClearAllChildren()
    if not ESTADO_PLAYER and not ESTADO_BOT then return end
    
    local charLocal = player.Character
    local rootLocal = charLocal and charLocal:FindFirstChild("HumanoidRootPart")
    if not rootLocal then return end

    for _, target in ipairs(workspace:GetDescendants()) do
        local hum = target:FindFirstChildOfClass("Humanoid")
        local root = target:FindFirstChild("HumanoidRootPart")
        
        if hum and root and target ~= charLocal and hum.Health > 0 then
            local dist = (rootLocal.Position - root.Position).Magnitude
            
            if dist <= DISTANCIA_MAXIMA then
                local isPlayer = Players:GetPlayerFromCharacter(target)
                
                -- Verifica se o ESP específico está ligado para renderizar
                if (isPlayer and ESTADO_PLAYER) or (not isPlayer and ESTADO_BOT) then
                    
                    local icon = isPlayer and "👤" or "🤖"
                    local baseColor = isPlayer and (isPlayer.TeamColor and isPlayer.TeamColor.Color or Color3.fromRGB(255, 255, 255)) or Color3.fromRGB(255, 50, 50)
                    
                    -- Highlight
                    local highlight = Instance.new("Highlight", espFolder)
                    highlight.Adornee = target
                    highlight.FillTransparency = 1
                    highlight.OutlineColor = baseColor
                    
                    -- Billboard
                    local billboard = Instance.new("BillboardGui", espFolder)
                    billboard.Size = UDim2.new(0, 200, 0, 50)
                    billboard.Adornee = target:FindFirstChild("Head") or root
                    billboard.AlwaysOnTop = true
                    billboard.ExtentsOffset = Vector3.new(0, 3, 0)
                    
                    local infoLabel = Instance.new("TextLabel", billboard)
                    infoLabel.Size = UDim2.new(1, 0, 1, 0)
                    infoLabel.BackgroundTransparency = 1
                    infoLabel.TextColor3 = baseColor
                    infoLabel.TextStrokeTransparency = 0.2
                    infoLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                    infoLabel.Font = Enum.Font.GothamBold
                    infoLabel.TextSize = 13
                    
                    infoLabel.Text = string.format("%s: %s\n📏 %d Metros | ❤ %d Vida", icon, target.Name, math.floor(dist), math.floor(hum.Health))
                end
            end
        end
    end
end

-- [LOOP OTIMIZADO]
task.spawn(function()
    while task.wait(0.5) do
        UpdateESP()
    end
end)

-- [EVENTOS DE CLIQUE]
playerBtn.MouseButton1Click:Connect(function()
    ESTADO_PLAYER = not ESTADO_PLAYER
    AnimarToggle(playerCircle, ESTADO_PLAYER)
    
    local txtEstado = ESTADO_PLAYER and "Ativado" or "Desativado"
    SistemaDeAvisos("ESP de Players", "O ESP de jogadores foi " .. txtEstado)
end)

botBtn.MouseButton1Click:Connect(function()
    ESTADO_BOT = not ESTADO_BOT
    AnimarToggle(botCircle, ESTADO_BOT)
    
    local txtEstado = ESTADO_BOT and "Ativado" or "Desativado"
    SistemaDeAvisos("ESP de Bots", "O ESP de bots foi " .. txtEstado)
end)
