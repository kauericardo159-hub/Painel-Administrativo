-- [NOTIFICAÇÃO E LOGICA VISUAL]
--------------------------------------------------------------------
local function Notify(msg, cor)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, 250, 0, 45)
    card.Position = UDim2.new(1, 20, 0.9, 0)
    card.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    card.Parent = panelGui
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke", card)
    s.Color = cor s.Thickness = 1.5

    local txt = Instance.new("TextLabel", card)
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.Text = msg
    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
    txt.Font = Enum.Font.JetBrainsMono
    txt.TextSize = 12
    txt.BackgroundTransparency = 1

    card:TweenPosition(UDim2.new(1, -270, 0.9, 0), "Out", "Quart", 0.4)
    task.wait(2.5)
    card:TweenPosition(UDim2.new(1, 20, 0.9, 0), "In", "Quart", 0.4)
    game:GetService("Debris"):AddItem(card, 0.5)
end

local function ToggleVisual(ativo, bg, circle)
    if ativo then
        TweenService:Create(circle, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = UDim2.new(0.55, 0, 0.5, -8), BackgroundColor3 = Color3.fromRGB(100, 255, 100)}):Play()
        TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(20, 40, 20)}):Play()
    else
        TweenService:Create(circle, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = UDim2.new(0.1, 0, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255, 100, 100)}):Play()
        TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 45)}):Play()
    end
end

-- [LÓGICA ESP]
local espFolder = Instance.new("Folder", workspace)
espFolder.Name = "V7_ESP_System"

local function UpdateESP()
    espFolder:ClearAllChildren()
    if not ESP_PLAYERS_ATIVO and not ESP_BOTS_ATIVO then return end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    for _, target in ipairs(workspace:GetDescendants()) do
        local hum = target:FindFirstChildOfClass("Humanoid")
        local root = target:FindFirstChild("HumanoidRootPart")
        
        if hum and root and target ~= char and hum.Health > 0 then
            local dist = (char.HumanoidRootPart.Position - root.Position).Magnitude
            if dist > DISTANCIA_MAXIMA then continue end

            local isPlr = Players:GetPlayerFromCharacter(target)
            if (isPlr and not ESP_PLAYERS_ATIVO) or (not isPlr and not ESP_BOTS_ATIVO) then continue end

            local color = isPlr and (isPlr.TeamColor.Color) or Color3.fromRGB(255, 255, 255)

            local hl = Instance.new("Highlight", espFolder)
            hl.Adornee = target
            hl.FillTransparency = 0.8
            hl.FillColor = color
            hl.OutlineColor = color
            hl.OutlineTransparency = 0

            local bb = Instance.new("BillboardGui", espFolder)
            bb.Size = UDim2.new(0, 200, 0, 50)
            bb.Adornee = target:FindFirstChild("Head") or root
            bb.AlwaysOnTop = true
            bb.ExtentsOffset = Vector3.new(0, 3, 0)

            local l = Instance.new("TextLabel", bb)
            l.Size = UDim2.new(1, 0, 1, 0)
            l.BackgroundTransparency = 1
            l.TextColor3 = color
            l.Font = Enum.Font.JetBrainsMono
            l.TextSize = 12
            l.TextStrokeTransparency = 0.5
            l.Text = string.format("%s\n[%dM]", target.Name, math.floor(dist))
        end
    end
end

task.spawn(function()
    while task.wait(0.5) do UpdateESP() end
end)

playerBtn.MouseButton1Click:Connect(function()
    ESP_PLAYERS_ATIVO = not ESP_PLAYERS_ATIVO
    ToggleVisual(ESP_PLAYERS_ATIVO, playerBg, playerCircle)
    Notify(ESP_PLAYERS_ATIVO and "PLAYERS RENDER: ON" or "PLAYERS RENDER: OFF", ESP_PLAYERS_ATIVO and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100))
end)

botBtn.MouseButton1Click:Connect(function()
