if listFrame:FindFirstChild(NOME_COMANDO) then
    listFrame[NOME_COMANDO]:Destroy()
end

-- [SISTEMA DE AVISOS (ESPAÇO RESERVADO PARA SEU FUTURO SCRIPT)]
