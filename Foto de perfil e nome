-- 4. FUNÇÃO PARA LABELS PREMIUM (Com Gradiente e Animação)
local function CreatePremiumLabel(name, pos, text, size, isBold)
    local label = Instance.new("TextLabel")
    label.Name = name
    label.Size = UDim2.new(0, 200, 0, 20)
    label.Position = pos + UDim2.new(0, 10, 0, 0) -- Offset para animação
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Text = text
    label.Font = isBold and Enum.Font.GothamBold or Enum.Font.Gotham
    label.TextSize = size
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTransparency = 1 -- Inicia invisível
    label.Parent = profileArea
    
    -- UIStroke na fonte para destaque
    local textStroke = Instance.new("UIStroke")
    textStroke.Thickness = 1.5
    textStroke.Color = Color3.new(0, 0, 0)
    textStroke.Transparency = 0.5
    textStroke.Parent = label

    -- Gradiente no Texto
    local textGradient = Instance.new("UIGradient")
    textGradient.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromRGB(180, 180, 180))
    textGradient.Rotation = 90
    textGradient.Parent = label

    return label
end

local nameLabel = CreatePremiumLabel("NameLabel", UDim2.new(0, 70, 0.3, 0), player.DisplayName, 18, true)
local userLabel = CreatePremiumLabel("UserLabel", UDim2.new(0, 70, 0.6, 5), "@" .. player.Name, 13, false)

-- 5. ANIMAÇÃO DE ENTRADA
local function animateProfile()
    local info = TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    
    -- A foto surge aumentando
    profileImage.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(profileImage, info, {Size = UDim2.new(0, 60, 0, 60)}):Play()
    
    -- Os nomes deslizam para a direita e aparecem
    task.wait(0.2)
    TweenService:Create(nameLabel, info, {Position = UDim2.new(0, 70, 0.3, 0), TextTransparency = 0}):Play()
    task.wait(0.1)
    TweenService:Create(userLabel, info, {Position = UDim2.new(0, 70, 0.6, 5), TextTransparency = 0.3}):Play()
end

-- Dispara a animação quando o painel se torna visível
painel:GetPropertyChangedSignal("Visible"):Connect(function()
    if painel.Visible then
        animateProfile()
    end
end)

print("Perfil Premium com Animação carregado no Topo!")
