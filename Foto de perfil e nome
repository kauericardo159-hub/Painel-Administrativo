local profileArea = Instance.new("Frame")
profileArea.Name = "UserProfileArea"
profileArea.Size = UDim2.new(0, 280, 0, 70)
profileArea.Position = UDim2.new(0, 15, 0, 15) -- Canto superior esquerdo
profileArea.BackgroundTransparency = 1
profileArea.Parent = painel

-- 3. FOTO DE PERFIL ESTILIZADA
local profileImage = Instance.new("ImageLabel")
profileImage.Name = "UserImage"
profileImage.Size = UDim2.new(0, 60, 0, 60)
profileImage.Position = UDim2.new(0, 0, 0.5, 0)
profileImage.AnchorPoint = Vector2.new(0, 0.5)
profileImage.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
profileImage.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
