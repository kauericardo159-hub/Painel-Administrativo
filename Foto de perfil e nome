local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

-- 1. LOCALIZAÇÃO DO PAINEL
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3", 5)
local painel = coreGui:WaitForChild("Panel") -- Ajustado para "Panel" conforme sistema

-- 2. CONTAINER DO PERFIL (Posicionado no Topo Esquerdo)
local profileArea = painel:FindFirstChild("UserProfileArea")
if not profileArea then
    profileArea = Instance.new("Frame")
    profileArea.Name = "UserProfileArea"
    profileArea.Size = UDim2.new(0, 280, 0, 70)
    profileArea.Position = UDim2.new(0, 15, 0, 15)
    profileArea.BackgroundTransparency = 1
    profileArea.Parent = painel
end

-- 3. FOTO DE PERFIL ESTILIZADA
local profileImage = profileArea:FindFirstChild("UserImage")
if not profileImage then
    profileImage = Instance.new("ImageLabel")
    profileImage.Name = "UserImage"
    profileImage.Size = UDim2.new(0, 60, 0, 60)
    profileImage.Position = UDim2.new(0, 0, 0.5, 0)
    profileImage.AnchorPoint = Vector2.new(0, 0.5)
    profileImage.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    profileImage.Parent = profileArea

    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(1, 0)
    uiCorner.Parent = profileImage

    -- Bordas da Foto (Branco com brilho)
    local fStroke = Instance.new("UIStroke")
    fStroke.Thickness = 2.5
    fStroke.Color = Color3.new(1, 1, 1)
    fStroke.Parent = profileImage
end

-- 4. FUNÇÃO PARA LABELS PREMIUM (Com Gradiente e Animação)
local function CreatePremiumLabel(name, pos, text, size, isBold)
    local label = profileArea:FindFirstChild(name)
    if not label then
        label = Instance.new("TextLabel")
        label.Name = name
        label.Size = UDim2.new(0, 200, 0, 20)
        label.BackgroundTransparency = 1
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = profileArea
        
        -- UIStroke na fonte para destaque
        local textStroke = Instance.new("UIStroke")
        textStroke.Thickness = 1.5
        textStroke.Color = Color3.new(0, 0, 0)
        textStroke.Transparency = 0.5
        textStroke.Parent = label

        -- UIGradient Estiloso (Dourado/Branco para destaque)
        local textGradient = Instance.new("UIGradient")
        textGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 200, 200))
        })
        textGradient.Rotation = 90
        textGradient.Parent = label
    end
    
    label.Position = pos
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Text = text
    label.Font = isBold and Enum.Font.GothamBold or Enum.Font.Gotham
    label.TextSize = size
    
    return label
end

-- 5. ATUALIZAÇÃO E ANIMAÇÃO
local function updateAndAnimateProfile()
    -- ATUALIZAÇÃO: Busca foto, nome e display name atuais
    profileImage.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
    local nameLabel = CreatePremiumLabel("NameLabel", UDim2.new(0, 70, 0.3, 0), player.DisplayName, 18, true)
    local userLabel = CreatePremiumLabel("UserLabel", UDim2.new(0, 70, 0.6, 5), "@" .. player.Name, 13, false)
    
    local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    
    -- Animação
    nameLabel.TextTransparency = 1
    userLabel.TextTransparency = 1
    profileImage.ImageTransparency = 1
    
    TweenService:Create(profileImage, info, {ImageTransparency = 0}):Play()
    TweenService:Create(nameLabel, info, {TextTransparency = 0}):Play()
    TweenService:Create(userLabel, info, {TextTransparency = 0.2}):Play()
end

-- Dispara a atualização quando o painel se torna visível
painel:GetPropertyChangedSignal("Visible"):Connect(function()
    if painel.Visible then
        updateAndAnimateProfile()
    end
end)

-- Executa uma vez ao carregar
updateAndAnimateProfile()
print("Perfil Premium Atualizado e Estiloso!")
