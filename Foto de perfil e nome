local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

--[[ 
===========================================================
       ⚙ GERENCIADOR DE PERFIL V6 (ESTILIZADO) ⚙
===========================================================
]]

-- 1. LOCALIZAÇÃO E LIMPEZA
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3")
local painel = coreGui:WaitForChild("Panel")

-- Limpa perfil anterior se existir
if painel:FindFirstChild("ProfileContainer") then
    painel.ProfileContainer:Destroy()
end

-- 2. CONTAINER DO PERFIL (Topo Esquerdo)
local profileContainer = Instance.new("Frame")
profileContainer.Name = "ProfileContainer"
profileContainer.Size = UDim2.new(0, 300, 0, 80) -- Tamanho compacto para o topo
profileContainer.Position = UDim2.new(0, 20, 0, 20)
profileContainer.BackgroundTransparency = 1
profileContainer.ZIndex = painel.ZIndex + 2
profileContainer.Parent = painel

-- 3. FOTO DE PERFIL (Imagem Arredondada)
local avatarImage = Instance.new("ImageLabel")
avatarImage.Name = "AvatarImage"
avatarImage.Size = UDim2.new(0, 60, 0, 60)
avatarImage.Position = UDim2.new(0, 10, 0.5, 0)
avatarImage.AnchorPoint = Vector2.new(0, 0.5)
avatarImage.BackgroundTransparency = 1
avatarImage.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
avatarImage.ZIndex = profileContainer.ZIndex + 1
avatarImage.Parent = profileContainer

-- UICorner na Foto
local avatarCorner = Instance.new("UICorner")
avatarCorner.CornerRadius = UDim.new(1, 0) -- Círculo
avatarCorner.Parent = avatarImage

-- UIStroke na Foto (Borda Branca)
local avatarStroke = Instance.new("UIStroke")
avatarStroke.Thickness = 2
avatarStroke.Color = Color3.fromRGB(255, 255, 255)
avatarStroke.Parent = avatarImage

-- 4. NOME DO USUÁRIO (Texto Estilizado)
local usernameLabel = Instance.new("TextLabel")
usernameLabel.Name = "UsernameLabel"
usernameLabel.Size = UDim2.new(1, -90, 1, 0)
usernameLabel.Position = UDim2.new(0, 80, 0, 0)
usernameLabel.BackgroundTransparency = 1
usernameLabel.Text = player.DisplayName
usernameLabel.Font = Enum.Font.GothamBold
usernameLabel.TextSize = 22
usernameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
usernameLabel.TextXAlignment = Enum.TextXAlignment.Left
usernameLabel.ZIndex = profileContainer.ZIndex + 1
usernameLabel.Parent = profileContainer

-- 5. ANIMAÇÃO DE ENTRADA (Slide suave)
local function animateProfile()
    profileContainer.Position = UDim2.new(0, -320, 0, 20) -- Começa fora da tela
    
    TweenService:Create(profileContainer, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 20, 0, 20)
    }):Play()
end

-- Sincronização com a abertura do painel
painel:GetPropertyChangedSignal("Visible"):Connect(function()
    if painel.Visible then
        task.wait(0.2) 
        animateProfile()
    end
end)

print("✅ Perfil V6 Carregado!")
