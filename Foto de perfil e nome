local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

-- 1. LOCALIZAÇÃO E LIMPEZA
local playerGui = player:WaitForChild("PlayerGui")
local coreGui = playerGui:WaitForChild("SistemaPainel_V3", 5)
local painel = coreGui:WaitForChild("Panel") -- Ajustado para "Panel" conforme sistema anterior

if painel:FindFirstChild("UserProfileArea") then
    painel.UserProfileArea:Destroy()
end

-- 2. CONTAINER DO PERFIL (Posicionado no Topo Esquerdo)
local profileArea = Instance.new("Frame")
profileArea.Name = "UserProfileArea"
profileArea.Size = UDim2.new(0, 280, 0, 70)
profileArea.Position = UDim2.new(0, 15, 0, 15) -- Canto superior esquerdo
profileArea.BackgroundTransparency = 1
profileArea.Parent = painel

-- 3. FOTO DE PERFIL ESTILIZADA
local profileImage = Instance.new("ImageLabel")
profileImage.Name = "UserImage"
profileImage.Size = UDim2.new(0, 60, 0, 60)
profileImage.Position = UDim2.new(0, 0, 0.5, 0)
profileImage.AnchorPoint = Vector2.new(0, 0.5)
profileImage.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
profileImage.Parent = profileArea

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(1, 0)
uiCorner.Parent = profileImage

-- Bordas da Foto (Branco com brilho)
local fStroke = Instance.new("UIStroke")
fStroke.Thickness = 2.5
fStroke.Color = Color3.new(1, 1, 1)
fStroke.Parent = profileImage

-- UIGradient na foto para um efeito premium
local imgGradient = Instance.new("UIGradient")
imgGradient.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromRGB(200, 200, 200))
imgGradient.Rotation = -45
imgGradient.Parent = profileImage

-- ==========================================
-- 4. FUNÇÃO DE ATUALIZAÇÃO (Fix Desatualização)
-- ==========================================
local function updateProfile()
    -- Busca a imagem mais recente
    local success, content = pcall(function()
        return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
    end)
    
    if success then
        profileImage.Image = content
    end
    
    -- Atualiza nomes
    local nameLabel = profileArea:FindFirstChild("NameLabel")
    local userLabel = profileArea:FindFirstChild("UserLabel")
    
    if nameLabel then nameLabel.Text = player.DisplayName end
    if userLabel then userLabel.Text = "@" .. player.Name end
end

-- Atualiza no início
updateProfile()

-- Atualiza se o jogador mudar o visual ou nome
player.CharacterAppearanceLoaded:Connect(updateProfile)
player:GetPropertyChangedSignal("DisplayName"):Connect(updateProfile)

-- ==========================================
-- 5. LABELS PREMIUM (Com Gradiente)
-- ==========================================
local function CreatePremiumLabel(name, pos, text, size, isBold)
    local label = Instance.new("TextLabel")
    label.Name = name
    label.Size = UDim2.new(0, 200, 0, 20)
    label.Position = pos
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Text = text
    label.Font = isBold and Enum.Font.GothamBold or Enum.Font.Gotham
    label.TextSize = size
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = profileArea
    
    local textStroke = Instance.new("UIStroke")
    textStroke.Thickness = 1.5
    textStroke.Color = Color3.new(0, 0, 0)
    textStroke.Transparency = 0.5
    textStroke.Parent = label

    local textGradient = Instance.new("UIGradient")
    textGradient.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromRGB(180, 180, 180))
    textGradient.Rotation = 90
    textGradient.Parent = label

    return label
end

CreatePremiumLabel("NameLabel", UDim2.new(0, 75, 0.2, 0), player.DisplayName, 18, true)
CreatePremiumLabel("UserLabel", UDim2.new(0, 75, 0.6, 0), "@" .. player.Name, 13, false)

print("Perfil Premium Atualizado e Estiloso!")
