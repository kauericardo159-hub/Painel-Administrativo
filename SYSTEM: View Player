local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES
local MAX_DISTANCE = 400
local FADE_START_DISTANCE = 300 -- Começa a desaparecer nesta distância
local UPDATE_RATE = 0.05 -- 20 FPS para lógica
local heartBeatCounter = 0

-- ESTADO GLOBAL (Conectado ao switch do painel)
-- Nota: O painel deve controlar esta variável global
_G.ViewPlayerActive = _G.ViewPlayerActive or false

-- CACHE DE ELEMENTOS (Para desempenho e limpeza)
local activeHighlights = {}
local activeUIs = {}

-- FUNÇÃO: LIMPEZA DE UM PLAYER ESPECÍFICO
local function clearPlayerEffects(player)
    if activeHighlights[player] then
        activeHighlights[player]:Destroy()
        activeHighlights[player] = nil
    end
    if activeUIs[player] then
        activeUIs[player]:Destroy()
        activeUIs[player] = nil
    end
end

-- FUNÇÃO: LIMPEZA TOTAL (Ao desativar o sistema)
local function forceFullCleanup()
    for player, hl in pairs(activeHighlights) do if hl then hl:Destroy() end end
    for player, ui in pairs(activeUIs) do if ui then ui:Destroy() end end
    table.clear(activeHighlights)
    table.clear(activeUIs)
end

-- FUNÇÃO: CRIAR/ATUALIZAR UI DA CABEÇA
local function updatePlayerUI(player, head, distance)
    local ui = activeUIs[player]
    
    if not ui then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "PlayerViewUI"
        billboard.Size = UDim2.new(0, 200, 0, 60)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.LightInfluence = 0
        billboard.Parent = head
        
        local mainLabel = Instance.new("TextLabel")
        mainLabel.Name = "MainLabel"
        mainLabel.Size = UDim2.new(1, 0, 0.5, 0)
        mainLabel.BackgroundTransparency = 1
        mainLabel.Font = Enum.Font.GothamBold
        mainLabel.TextSize = 14
        mainLabel.RichText = true
        mainLabel.TextStrokeTransparency = 0.5
        mainLabel.Parent = billboard
        
        local statsLabel = Instance.new("TextLabel")
        statsLabel.Name = "StatsLabel"
        statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
        statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
        statsLabel.BackgroundTransparency = 1
        statsLabel.Font = Enum.Font.GothamMedium
        statsLabel.TextSize = 12
        statsLabel.RichText = true
        statsLabel.TextStrokeTransparency = 0.5
        statsLabel.Parent = billboard
        
        activeUIs[player] = billboard
        ui = billboard
    end
    
    -- Cálculos de Cor e Fade
    local teamColor = player.TeamColor.Color
    local health = player.Character.Humanoid.Health
    local maxHealth = player.Character.Humanoid.MaxHealth
    
    -- Calcula transparência baseada na distância (Fade Effect)
    local transparency = 0
    if distance > FADE_START_DISTANCE then
        transparency = math.clamp((distance - FADE_START_DISTANCE) / (MAX_DISTANCE - FADE_START_DISTANCE), 0, 1)
    end
    
    -- Aplica textos com cores
    ui.MainLabel.Text = string.format('<font color="rgb(%d,%d,%d)">👤: %s</font>', teamColor.R*255, teamColor.G*255, teamColor.B*255, player.DisplayName)
    ui.StatsLabel.Text = string.format('<font color="rgb(180,180,0)">📏: %dM.</font> | <font color="rgb(150,0,0)">❤: %d</font>', math.floor(distance), math.floor(health))
    
    -- Aplica Fade na UI
    ui.MainLabel.TextTransparency = transparency
    ui.MainLabel.TextStrokeTransparency = 0.5 + (transparency * 0.5)
    ui.StatsLabel.TextTransparency = transparency
    ui.StatsLabel.TextStrokeTransparency = 0.5 + (transparency * 0.5)
end

-- FUNÇÃO: APLICAR OUTLINE COM FADE
local function updatePlayerOutline(player, char, distance)
    local hl = activeHighlights[player]
    
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "PlayerHighlight"
        hl.FillTransparency = 1
        hl.Parent = char
        activeHighlights[player] = hl
    end
    
    -- Outline cor do time
    hl.OutlineColor = player.TeamColor.Color
    
    -- Aplica Fade na Outline
    local transparency = 0
    if distance > FADE_START_DISTANCE then
        transparency = math.clamp((distance - FADE_START_DISTANCE) / (MAX_DISTANCE - FADE_START_DISTANCE), 0, 1)
    end
    hl.OutlineTransparency = transparency
end

-- LOOP PRINCIPAL
RunService.Heartbeat:Connect(function(dt)
    if not _G.ViewPlayerActive then
        if next(activeHighlights) or next(activeUIs) then
            forceFullCleanup()
        end
        return
    end
    
    heartBeatCounter = heartBeatCounter + dt
    if heartBeatCounter < UPDATE_RATE then return end
    heartBeatCounter = 0
    
    local myChar = localPlayer.Character
    local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local char = player.Character
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")
            local distance = (hrp.Position - char.HumanoidRootPart.Position).Magnitude
            
            if distance <= MAX_DISTANCE and humanoid and humanoid.Health > 0 and head then
                updatePlayerUI(player, head, distance)
                updatePlayerOutline(player, char, distance)
            else
                clearPlayerEffects(player)
            end
        else
            -- Player desconectou ou morreu
            clearPlayerEffects(player)
        end
    end
end)
