local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE TOGGLE (LIGA/DESLIGA)
-- ==========================================
if _G.SystemViewPlayerConnection then
    _G.SystemViewPlayerConnection:Disconnect()
    _G.SystemViewPlayerConnection = nil
    
    -- CORREÇÃO: Limpeza profunda do Cache ao desativar
    if _G.PlayerCacheViewPlayer then
        for _, visualData in pairs(_G.PlayerCacheViewPlayer) do
            if visualData.Highlight then visualData.Highlight:Destroy() end
            if visualData.UI then visualData.UI:Destroy() end
        end
        table.clear(_G.PlayerCacheViewPlayer)
    end
    
    if _G.SystemViewPlayerFolder then
        _G.SystemViewPlayerFolder:Destroy()
        _G.SystemViewPlayerFolder = nil
    end
    
    print("[SYSTEM] View Player: DESATIVADO E LIMPO")
    return
end

print("[SYSTEM] View Player: ATIVADO")

-- ==========================================
-- CONFIGURAÇÕES
-- ==========================================
local MAX_DISTANCE = 400
local FADE_START = 150

-- Cores Fixas (Formato Hexadecimal)
local DIST_COLOR = "#C8C800"
local HP_COLOR = "#B40000"

-- Pasta Global
_G.SystemViewPlayerFolder = Instance.new("Folder")
_G.SystemViewPlayerFolder.Name = "ViewPlayerCache"
_G.SystemViewPlayerFolder.Parent = localPlayer:WaitForChild("PlayerGui")

-- Cache Global para facilitar a limpeza
_G.PlayerCacheViewPlayer = {}
local localCache = _G.PlayerCacheViewPlayer

-- ==========================================
-- FUNÇÕES AUXILIARES
-- ==========================================
local function getTeamColor(player)
    if player.Team then
        return player.TeamColor.Color
    end
    return Color3.fromRGB(255, 255, 255)
end

local function createVisuals(player)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "PlayerOutline"
    hl.FillTransparency = 1
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "PlayerInfo"
    bg.Size = UDim2.new(0, 200, 0, 45)
    bg.StudsOffset = Vector3.new(0, 1.5, 0)
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemViewPlayerFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.RichText = true
    nameLabel.Parent = bg
    
    local statsLabel = Instance.new("TextLabel")
    statsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.TextStrokeTransparency = 0.5
    statsLabel.RichText = true
    statsLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.NameLabel = nameLabel
    data.StatsLabel = statsLabel
    
    return data
end

-- ==========================================
-- LOOP DE RENDERIZAÇÃO
-- ==========================================
_G.SystemViewPlayerConnection = RunService.RenderStepped:Connect(function()
    local myChar = localPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if not myHRP then return end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            local char = p.Character
            local head = char and char:FindFirstChild("Head")
            local hum = char and char:FindFirstChild("Humanoid")
            
            if char and head and hum and hum.Health > 0 then
                local dist = (myHRP.Position - head.Position).Magnitude
                
                if dist <= MAX_DISTANCE then
                    if not localCache[p] then
                        localCache[p] = createVisuals(p)
                    end
                    
                    local vis = localCache[p]
                    local tColor = getTeamColor(p)
                    
                    local fade = math.clamp((dist - FADE_START) / (MAX_DISTANCE - FADE_START), 0, 1)
                    
                    -- CORREÇÃO: Highlight Parent
                    vis.Highlight.Parent = char
                    vis.Highlight.OutlineColor = tColor
                    vis.Highlight.OutlineTransparency = fade
                    
                    vis.UI.Adornee = head
                    vis.UI.Enabled = true
                    
                    local hexTeam = string.format("#%02X%02X%02X", tColor.R*255, tColor.G*255, tColor.B*255)
                    
                    local strokeFade = 0.5 + (fade * 0.5)
                    vis.NameLabel.TextStrokeTransparency = strokeFade
                    vis.StatsLabel.TextStrokeTransparency = strokeFade
                    vis.NameLabel.TextTransparency = fade
                    vis.StatsLabel.TextTransparency = fade
                    
                    vis.NameLabel.Text = string.format('<font color="%s">👤: %s</font>', hexTeam, p.DisplayName)
                    vis.StatsLabel.Text = string.format('<font color="%s">📏: %dm.</font> | <font color="%s">❤: %d</font>', DIST_COLOR, math.floor(dist), HP_COLOR, math.floor(hum.Health))
                else
                    -- Fora da distância: Oculta visualmente, mas mantém no cache para performance
                    if localCache[p] then
                        localCache[p].Highlight.Parent = nil
                        localCache[p].UI.Enabled = false
                    end
                end
            else
                -- Sem personagem: Oculta
                if localCache[p] then
                    localCache[p].Highlight.Parent = nil
                    localCache[p].UI.Enabled = false
                end
            end
        else
            -- CORREÇÃO: Limpa cache se o player saiu do servidor
            if localCache[p] then
                if localCache[p].Highlight then localCache[p].Highlight:Destroy() end
                if localCache[p].UI then localCache[p].UI:Destroy() end
                localCache[p] = nil
            end
        end
    end
end)
