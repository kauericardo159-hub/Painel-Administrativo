-- [SISTEMA DE NOTIFICAÇÃO (CARDS)]
local function Notify(msg, cor)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, 260, 0, 50)
    card.Position = UDim2.new(1, 20, 0.85, 0)
    card.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    card.Parent = panelGui
    
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)
    local s = Instance.new("UIStroke", card)
    s.Color = cor s.Thickness = 2

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.Text = msg
    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 13
    txt.BackgroundTransparency = 1
    txt.Parent = card

    card:TweenPosition(UDim2.new(1, -280, 0.85, 0), "Out", "Quart", 0.5)
    task.wait(3)
    card:TweenPosition(UDim2.new(1, 20, 0.85, 0), "In", "Quart", 0.5)
    game:GetService("Debris"):AddItem(card, 0.6)
end

-- [ANIMAÇÃO DO SWITCH]
local function ToggleSwitch(ativo)
    if ativo then
        TweenService:Create(switchCircle, TweenInfo.new(0.3), {Position = UDim2.new(0.55, 0, 0.5, -8), BackgroundColor3 = Color3.fromRGB(80, 255, 80)}):Play()
        TweenService:Create(switchBg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(30, 60, 30)}):Play()
    else
        TweenService:Create(switchCircle, TweenInfo.new(0.3), {Position = UDim2.new(0.1, 0, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255, 80, 80)}):Play()
        TweenService:Create(switchBg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 55)}):Play()
    end
end

-- [LÓGICA DO ESP]
local itemEspFolder = Instance.new("Folder", workspace)
itemEspFolder.Name = "V4_ItemESP_Storage"

local function IsRealItem(obj)
    if not obj:IsA("BasePart") or obj.Name ~= "Handle" or obj.Transparency >= 1 then return false end
    local p = obj.Parent
    if p:IsA("Accessory") or p:IsA("Hat") then return false end
    if p:FindFirstAncestorOfClass("Model") and p:FindFirstAncestorOfClass("Model"):FindFirstChild("Humanoid") then return false end
    return true
end

local function UpdateItemESP()
    itemEspFolder:ClearAllChildren()
    if not ESTADO_ATIVO then return end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if IsRealItem(obj) then
            local dist = (obj.Position - root.Position).Magnitude
            if dist <= DISTANCIA_MAXIMA then
                -- Visual
                local hl = Instance.new("Highlight", itemEspFolder)
                hl.Adornee = obj.Parent
                hl.FillTransparency = 1
                hl.OutlineColor = Color3.fromRGB(255, 165, 0) -- Laranja Clássico

                local bb = Instance.new("BillboardGui", itemEspFolder)
                bb.Size = UDim2.new(0, 150, 0, 40)
                bb.Adornee = obj
                bb.AlwaysOnTop = true
                bb.ExtentsOffset = Vector3.new(0, 2, 0)

                local l = Instance.new("TextLabel", bb)
                l.Size = UDim2.new(1, 0, 1, 0)
                l.BackgroundTransparency = 1
                l.Text = string.format("📦 %s\n📏 %dM", obj.Parent.Name, math.floor(dist))
                l.TextColor3 = Color3.fromRGB(255, 255, 255)
                l.Font = Enum.Font.GothamBold
                l.TextSize = 12
                l.Parent = bb
            end
        end
    end
end

-- Loop
task.spawn(function()
    while task.wait(1) do UpdateItemESP() end
end)

-- Clique
clickBtn.MouseButton1Click:Connect(function()
    ESTADO_ATIVO = not ESTADO_ATIVO
    ToggleSwitch(ESTADO_ATIVO)
    Notify(ESTADO_ATIVO and "ITEM SCANNER: ATIVO" or "ITEM SCANNER: INATIVO", ESTADO_ATIVO and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80))
end)
