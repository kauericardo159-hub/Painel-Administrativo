--[[
    ====================================================================
    PROJETO: Painel V7.0 - Lista de Opções (Sidebar)
    DESCRIÇÃO: Cria os botões na barra lateral e gerencia o sistema de abas.
    ====================================================================
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Localiza a interface base (criada no script anterior)
local screenGui = playerGui:WaitForChild("PainelV7_ScreenGui")
local mainFrame = screenGui:WaitForChild("MainFrame")

local optionsContainer = mainFrame:WaitForChild("OptionsBox"):WaitForChild("OptionsContainer")
local titleText = mainFrame:WaitForChild("TitleBox"):WaitForChild("TitleText")
local pagesFolder = mainFrame:WaitForChild("ContentBox"):WaitForChild("PagesFolder")

-- Configurações Visuais dos Botões
local ESTILO = {
    CorInativo = Color3.fromRGB(25, 25, 30),
    CorAtivo = Color3.fromRGB(45, 45, 55),
    TextoInativo = Color3.fromRGB(170, 170, 175),
    TextoAtivo = Color3.fromRGB(255, 255, 255),
    BordaCinza = Color3.fromRGB(80, 80, 85)
}

-- Organiza os botões em formato de lista (um embaixo do outro)
local listLayout = Instance.new("UIListLayout", optionsContainer)
listLayout.SortOrder = Enum.SortOrder.LayoutOrder
listLayout.Padding = UDim.new(0, 10)
listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- Tabela para armazenar os botões criados
local abasCriadas = {}

-- Função Principal para criar os botões e suas páginas
local function CriarAba(nomeDaAba, icone, isDefault)
    -- 1. Cria o Botão na Sidebar
    local btn = Instance.new("TextButton")
    btn.Name = nomeDaAba .. "_Btn"
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.BackgroundColor3 = isDefault and ESTILO.CorAtivo or ESTILO.CorInativo
    btn.Text = "  " .. icone .. " " .. nomeDaAba
    btn.TextColor3 = isDefault and ESTILO.TextoAtivo or ESTILO.TextoInativo
    btn.Font = Enum.Font.Jura
    btn.TextSize = 16
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false -- Desativa o brilho padrão do Roblox
    btn.Parent = optionsContainer

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = ESTILO.BordaCinza
    stroke.Thickness = 1
    stroke.Transparency = isDefault and 0 or 0.5 -- Borda mais fraca se inativo

    -- 2. Cria a Página de Conteúdo invisível (Aguardando o Script 2)
    local pagina = Instance.new("Frame")
    pagina.Name = nomeDaAba .. "Page"
    pagina.Size = UDim2.new(1, -20, 1, -50)
    pagina.Position = UDim2.new(0, 10, 0, 45)
    pagina.BackgroundTransparency = 1
    pagina.Visible = isDefault
    pagina.Parent = pagesFolder

    table.insert(abasCriadas, {Botao = btn, Pagina = pagina, Nome = nomeDaAba})

    -- 3. Efeitos de Interação (Hover e Click)
    btn.MouseEnter:Connect(function()
        if not pagina.Visible then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 40)}):Play()
        end
    end)

    btn.MouseLeave:Connect(function()
        if not pagina.Visible then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = ESTILO.CorInativo}):Play()
        end
    end)

    btn.MouseButton1Click:Connect(function()
        -- Atualiza o Título Principal
        titleText.Text = string.upper(nomeDaAba)

        -- Desativa todas as outras abas
        for _, dados in ipairs(abasCriadas) do
            dados.Pagina.Visible = false
            TweenService:Create(dados.Botao, TweenInfo.new(0.3), {
                BackgroundColor3 = ESTILO.CorInativo, 
                TextColor3 = ESTILO.TextoInativo
            }):Play()
            dados.Botao.UIStroke.Transparency = 0.5
        end

        -- Ativa a aba clicada
        pagina.Visible = true
        TweenService:Create(btn, TweenInfo.new(0.3), {
            BackgroundColor3 = ESTILO.CorAtivo, 
            TextColor3 = ESTILO.TextoAtivo
        }):Play()
        stroke.Transparency = 0
    end)
end

-- ==========================================
-- INICIANDO AS ABAS
-- ==========================================
CriarAba("Comandos", "⚡", true)   -- 'true' faz ela ser a aba aberta ao iniciar
CriarAba("Visuais", "👁️", false)
CriarAba("Configurações", "⚙️", false)

print("[Painel V7] Lista de Opções carregada com sucesso!")
