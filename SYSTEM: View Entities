-- LOOP DE RENDERIZAÇÃO (ESP INFINITA)
-- ==========================================
_G.SystemViewEntitiesConnection = RunService.RenderStepped:Connect(function()
    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Varre o Workspace em busca de entidades
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isValidEntity(obj) then
            local root = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")) or obj
            
            if root and root:IsA("BasePart") then
                if not entityCache[obj] then
                    entityCache[obj] = createEntityVisual(obj)
                end
                
                local vis = entityCache[obj]
                local dist = (hrp.Position - root.Position).Magnitude
                
                -- Atualiza Posição e Texto
                vis.UI.Adornee = root
                vis.Label.Text = string.format("⚠️ %s ⚠️\n<font color='#C8C800'>%dm.</font>", obj.Name:upper(), math.floor(dist))
                
                -- Garante que o Highlight permaneça
                if vis.Highlight.Parent ~= obj then
                    vis.Highlight.Parent = obj
                end
            end
        end
    end

    -- Limpa o cache de entidades que sumiram do mapa
    for obj, vis in pairs(entityCache) do
        if not obj or not obj.Parent then
            vis.UI:Destroy()
            vis.Highlight:Destroy()
            entityCache[obj] = nil
        end
    end
end)

