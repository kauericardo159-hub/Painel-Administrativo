_G.SystemEntitiesFolder = Instance.new("Folder")
_G.SystemEntitiesFolder.Name = "EntitiesVisuals"
_G.SystemEntitiesFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.EntitiesCache = {}
local entityCache = _G.EntitiesCache

-- Lista de nomes comuns de entidades (Doors & The Rooms)
local ENTITY_NAMES = {
    "Rush", "Ambush", "Eyes", "Screech", "Halt", "Seek", "Figure", "Glitch", "Jack", "Timothy", "Hide", "Dupe", -- Doors
    "A-60", "A-120", "A-90", -- The Rooms
    "Dread", "Lookman", "Haste", "Pandemonium", "HaltMoving" -- Extras/Hard Mode
}

-- ==========================================
-- FUNÇÕES DE CRIAÇÃO VISUAL
-- ==========================================
local function createEntityVisual(model)
    local data = {}
    
    -- Outline Vermelho Intenso
    local hl = Instance.new("Highlight")
    hl.Name = "EntityESP"
    hl.FillTransparency = 0.5
    hl.FillColor = Color3.fromRGB(255, 0, 0)
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.OutlineTransparency = 0
    hl.Parent = model
    
    -- UI de Texto
    local bg = Instance.new("BillboardGui")
    bg.Name = "EntityInfo"
    bg.Size = UDim2.new(0, 200, 0, 50)
    bg.AlwaysOnTop = true
    bg.LightInfluence = 0
    bg.Parent = _G.SystemEntitiesFolder
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 16
    textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.RichText = true
    textLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.Label = textLabel
    return data
end

-- Função para validar se o objeto é uma entidade válida
local function isValidEntity(obj)
    -- Filtro anti-Pressure (Garante que não detecte nada desse jogo)
    if obj:FindFirstChild("PressureID") or obj.Name:find("Sebastian") then return false end
    
    -- Verifica se o nome está na lista ou se tem características de entidade de Doors
    for _, name in ipairs(ENTITY_NAMES) do
        if obj.Name == name or obj.Name:find(name) then
            return true
        end
    end
    
    -- Detecção por Humanoid (para entidades customizadas) que não são Players
    if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
        return true
    end
    
    return false
end

