local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE TOGGLE (LIGA/DESLIGA)
-- ==========================================
local function ClearSystem()
    if _G.SystemViewEntitiesRenderConn then _G.SystemViewEntitiesRenderConn:Disconnect() _G.SystemViewEntitiesRenderConn = nil end
    if _G.SystemViewEntitiesAddedConn then _G.SystemViewEntitiesAddedConn:Disconnect() _G.SystemViewEntitiesAddedConn = nil end
    
    if _G.EntitiesCache then
        for _, vis in pairs(_G.EntitiesCache) do
            if vis.Highlight then vis.Highlight:Destroy() end
            if vis.UI then vis.UI:Destroy() end
        end
        table.clear(_G.EntitiesCache)
    end
    
    if _G.SystemEntitiesFolder then
        _G.SystemEntitiesFolder:Destroy()
        _G.SystemEntitiesFolder = nil
    end
end

if _G.SystemViewEntitiesRenderConn or _G.SystemViewEntitiesAddedConn then
    ClearSystem()
    print("[SYSTEM] View Entities: DESATIVADO")
    return
end

print("[SYSTEM] View Entities: ATIVADO")

-- ==========================================
-- CONFIGURAÇÕES E LISTA DE MONSTROS
-- ==========================================
_G.SystemEntitiesFolder = Instance.new("Folder")
_G.SystemEntitiesFolder.Name = "EntitiesVisuals"
_G.SystemEntitiesFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.EntitiesCache = {}
local entityCache = _G.EntitiesCache

-- Lista de nomes e fragmentos de nomes das entidades ativas (Hotel, Rooms, Mines, Modifiers)
local ENTITY_KEYWORDS = {
    "rushmoving", "ambushmoving", "seekmoving", "figure", -- Hotel Padrão
    "a-60", "a60", "a-90", "a90", "a-120", "a120", -- The Rooms
    "grumble", "giggler", "gloombat", -- Floor 2 (The Mines)
    "pandemonium", "blitz", "lookman", "haste", "dread" -- Modificadores e Extras
}

-- ==========================================
-- LÓGICA DE DETECÇÃO IMEDIATA
-- ==========================================
local function isEntity(obj)
    if not obj then return false end
    -- Evita marcar sons, salas ou ragdolls mortos
    if obj:IsA("Sound") or string.find(string.lower(obj.Name), "ragdoll") or string.find(string.lower(obj.Name), "room") then 
        return false 
    end
    
    -- Tem que ser Model ou BasePart para ter posição física
    if not obj:IsA("Model") and not obj:IsA("BasePart") then return false end

    local name = string.lower(obj.Name)
    for _, kw in ipairs(ENTITY_KEYWORDS) do
        if string.find(name, kw) then
            return true
        end
    end
    return false
end

-- ==========================================
-- FUNÇÕES DE CRIAÇÃO VISUAL
-- ==========================================
local function createEntityVisual(obj)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "EntityESP"
    hl.FillTransparency = 0.5
    hl.FillColor = Color3.fromRGB(255, 0, 0)
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.OutlineTransparency = 0
    hl.Parent = obj
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "EntityInfo"
    bg.Size = UDim2.new(0, 200, 0, 50)
    bg.AlwaysOnTop = true
    bg.Parent = _G.SystemEntitiesFolder
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 16
    textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.RichText = true
    textLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.Label = textLabel
    data.Obj = obj
    return data
end

-- Função que tenta adicionar a entidade ao sistema
local function tryAddEntity(obj)
    if isEntity(obj) and not entityCache[obj] then
        entityCache[obj] = createEntityVisual(obj)
    end
end

-- ==========================================
-- INICIALIZAÇÃO E EVENTOS EM TEMPO REAL
-- ==========================================

-- 1. Varredura inicial (Pega o Figure ou entidades que já estão no mapa)
for _, obj in ipairs(workspace:GetDescendants()) do
    tryAddEntity(obj)
end

-- 2. DETECÇÃO INSTANTÂNEA (A mágica acontece aqui)
-- Sempre que o jogo invocar algo no mapa, ele verifica em milissegundos.
_G.SystemViewEntitiesAddedConn = workspace.DescendantAdded:Connect(function(obj)
    tryAddEntity(obj)
end)

-- ==========================================
-- LOOP DE ATUALIZAÇÃO DE POSIÇÃO E DISTÂNCIA
-- ==========================================
_G.SystemViewEntitiesRenderConn = RunService.RenderStepped:Connect(function()
    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if not hrp then return end

    for obj, vis in pairs(entityCache) do
        if obj and obj.Parent then
            -- Tenta achar o centro da entidade
            local root = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
            
            if root then
                local dist = (hrp.Position - root.Position).Magnitude
                
                vis.UI.Adornee = root
                vis.UI.Enabled = true
                vis.Label.Text = string.format("⚠️ %s ⚠️\n<font color='#C8C800'>%dm.</font>", obj.Name:upper(), math.floor(dist))
                
                -- Impede que o jogo remova o Highlight
                if vis.Highlight.Parent ~= obj then
                    vis.Highlight.Parent = obj
                end
            end
        else
            -- A entidade foi destruída (passou por você ou foi deletada pelo jogo)
            if vis.Highlight then vis.Highlight:Destroy() end
            if vis.UI then vis.UI:Destroy() end
            entityCache[obj] = nil
        end
    end
end)
