local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- ==========================================
-- SISTEMA DE TOGGLE (LIGA/DESLIGA)
-- ==========================================
if _G.SystemViewEntitiesConnection then
    _G.SystemViewEntitiesConnection:Disconnect()
    _G.SystemViewEntitiesConnection = nil
    
    if _G.EntitiesCache then
        for _, visualData in pairs(_G.EntitiesCache) do
            if visualData.Highlight then visualData.Highlight:Destroy() end
            if visualData.UI then visualData.UI:Destroy() end
        end
        table.clear(_G.EntitiesCache)
    end
    
    if _G.SystemEntitiesFolder then
        _G.SystemEntitiesFolder:Destroy()
        _G.SystemEntitiesFolder = nil
    end
    
    print("[SYSTEM] View Entities: DESATIVADO")
    return
end

print("[SYSTEM] View Entities: ATIVADO")

-- ==========================================
-- CONFIGURAÇÕES RESTRITAS
-- ==========================================
local MAX_DISTANCE = 1000 -- Limite solicitado
local SCAN_INTERVAL = 0.5 -- Varre o mapa a cada 0.5s (Economiza muito FPS)

_G.SystemEntitiesFolder = Instance.new("Folder")
_G.SystemEntitiesFolder.Name = "EntitiesVisuals"
_G.SystemEntitiesFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.EntitiesCache = {}
local entityCache = _G.EntitiesCache

-- Lista exata de entidades de ataque (Doors & Rooms)
local ATTACK_ENTITIES = {
    ["RushNew"] = true, ["Ambush"] = true, ["SeekMoving"] = true, 
    ["Figure"] = true, ["A60"] = true, ["A120"] = true, 
    ["A90"] = true, ["Halt"] = true, ["Pandemonium"] = true
}

-- ==========================================
-- FUNÇÕES DE CRIAÇÃO
-- ==========================================
local function createEntityVisual(model)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "EntityESP"
    hl.FillTransparency = 1 -- Apenas Outline para não poluir
    hl.OutlineColor = Color3.fromRGB(255, 0, 0)
    hl.OutlineTransparency = 0
    hl.Parent = model
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "EntityInfo"
    bg.Size = UDim2.new(0, 200, 0, 50)
    bg.AlwaysOnTop = true
    bg.Parent = _G.SystemEntitiesFolder
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 16
    textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    textLabel.TextStrokeTransparency = 0
    textLabel.RichText = true
    textLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.Label = textLabel
    return data
end

-- ==========================================
-- LOOP DE PERFORMANCE
-- ==========================================
local lastScan = 0

_G.SystemViewEntitiesConnection = RunService.RenderStepped:Connect(function()
    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 1. VARREDURA OTIMIZADA (Não roda todo frame)
    if tick() - lastScan > SCAN_INTERVAL then
        lastScan = tick()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if ATTACK_ENTITIES[obj.Name] and obj:IsA("Model") then
                local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if root then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist <= MAX_DISTANCE then
                        if not entityCache[obj] then
                            entityCache[obj] = createEntityVisual(obj)
                        end
                    end
                end
            end
        end
    end

    -- 2. ATUALIZAÇÃO DE UI (Roda todo frame para suavidade)
    for obj, vis in pairs(entityCache) do
        if obj and obj.Parent then
            local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if root then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist <= MAX_DISTANCE then
                    vis.UI.Adornee = root
                    vis.UI.Enabled = true
                    vis.Highlight.Enabled = true
                    vis.Label.Text = string.format("⚠️ %s ⚠️\n%dm.", obj.Name:upper(), math.floor(dist))
                else
                    vis.UI.Enabled = false
                    vis.Highlight.Enabled = false
                end
            end
        else
            vis.UI:Destroy()
            vis.Highlight:Destroy()
            entityCache[obj] = nil
        end
    end
end)
