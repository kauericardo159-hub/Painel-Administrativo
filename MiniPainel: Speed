-- 4. BOTÕES (Aplicar e Resetar)
local function createButton(name, text, color, posY)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0.4, 0, 0, 25)
    btn.Position = UDim2.new(0.55, 0, posY, 0)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = miniPainel
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    return btn
end

local applyBtn = createButton("ApplyBtn", "Aplicar Vel.", Color3.fromRGB(0, 150, 0), 0.45)
