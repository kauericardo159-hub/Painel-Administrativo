-- 4. BOTÕES (Aplicar e Resetar Estilosos)
local function createButton(name, text, color, posY)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0.42, 0, 0, 32)
    btn.Position = UDim2.new(0.53, 0, posY, 0)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = miniPainel
    btn.AutoButtonColor = true
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    return btn
end

-- Cores vibrantes modernas
local applyBtn = createButton("ApplyBtn", "Aplicar", Color3.fromRGB(30, 170, 50), 0.43)
local resetBtn = createButton("ResetBtn", "Resetar", Color3.fromRGB(170, 30, 30), 0.65)

-- 5. LÓGICA DE FUNCIONAMENTO (Conectada ao Sistema)
local function runSpeedSystem(action)
    task.spawn(function()
        pcall(function()
            _G.Action = action -- Define a ação para o script externo
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kauericardo159-hub/Painel-Administrativo/refs/heads/main/SYSTEM%3A%20Speed"))()
        end)
    end)
end

applyBtn.MouseButton1Click:Connect(function()
    local speedValue = tonumber(valueInput.Text)
    if speedValue then
        runSpeedSystem("Apply") -- Chama o sistema para aplicar
        print("Aplicando velocidade: " .. speedValue)
    else
        valueInput.Text = "Erro"
        task.wait(1)
        valueInput.Text = "16"
    end
end)

resetBtn.MouseButton1Click:Connect(function()
    valueInput.Text = "16"
    runSpeedSystem("Reset") -- Chama o sistema para resetar
    print("Velocidade resetada")
end)

-- 6. ANIMAÇÃO DE ENTRADA (Slide e Pop)
miniPainel.Position = UDim2.new(1.2, 0, 0, 0)
TweenService:Create(miniPainel, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
