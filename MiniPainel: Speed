-- 4. BOTÕES (Aplicar e Resetar Aprimorados)
local function createButton(name, text, color, posY)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0.4, 0, 0, 28)
    btn.Position = UDim2.new(0.55, 0, posY, 0)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.Parent = miniPainel
    btn.AutoButtonColor = true
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    return btn
end

-- Cores mais vibrantes
local applyBtn = createButton("ApplyBtn", "Aplicar", Color3.fromRGB(30, 150, 45), 0.45)
local resetBtn = createButton("ResetBtn", "Resetar", Color3.fromRGB(150, 30, 30), 0.65)

-- 5. LÓGICA DE FUNCIONAMENTO
local function runSpeedSystem()
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kauericardo159-hub/Painel-Administrativo/refs/heads/main/SYSTEM%3A%20Speed"))()
        end)
    end)
end

applyBtn.MouseButton1Click:Connect(function()
    local speedValue = tonumber(valueInput.Text)
    if speedValue then
        runSpeedSystem()
        print("Aplicando velocidade: " .. speedValue)
    else
        valueInput.Text = "Erro"
        task.wait(1)
        valueInput.Text = "16"
    end
end)

resetBtn.MouseButton1Click:Connect(function()
    valueInput.Text = "16"
    runSpeedSystem()
    print("Velocidade resetada")
end)

-- 6. ANIMAÇÃO DE ENTRADA (Smooth)
miniPainel.Position = UDim2.new(1.2, 0, 0, 0)
TweenService:Create(miniPainel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
