local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES TÉCNICAS
local MAX_DISTANCE = 300
_G.ViewPlayerActive = _G.ViewPlayerActive or false
_G.ViewBotActive = _G.ViewBotActive or false

-- Cores solicitadas
local corAmareloEscuro = "rgb(180, 160, 0)"
local corVermelhoEscuro = "rgb(150, 0, 0)"
local corBotRed = "rgb(255, 0, 0)"

-- FUNÇÃO PARA LIMPAR ELEMENTOS QUANDO DESATIVADO
local function clearViewElements(character)
    if character then
        local head = character:FindFirstChild("Head")
        if head and head:FindFirstChild("ViewSystemUI") then
            head.ViewSystemUI:Destroy()
        end
        if character:FindFirstChild("ViewHighlight") then
            character.ViewHighlight:Destroy()
        end
    end
end

-- ESTRUTURA DE TEXTO ORGANIZADA
local function createHeadUI(parent)
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ViewSystemUI"
    billboard.Size = UDim2.new(0, 250, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = parent

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "NameLabel"
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 16
    nameLabel.RichText = true
    nameLabel.Parent = billboard

    local statsLabel = Instance.new("TextLabel")
    statsLabel.Name = "StatsLabel"
    statsLabel.Size = UDim2.new(1, 0, 0.4, 0)
    statsLabel.Position = UDim2.new(0, 0, 0.5, 0)
    statsLabel.BackgroundTransparency = 1
    statsLabel.Font = Enum.Font.GothamMedium
    statsLabel.TextSize = 13
    statsLabel.RichText = true
    statsLabel.Parent = billboard

    return billboard, nameLabel, statsLabel
end

-- APLICAR HIGHLIGHT (OUTLINE)
local function applyOutline(model, color)
    local highlight = model:FindFirstChild("ViewHighlight") or Instance.new("Highlight")
    highlight.Name = "ViewHighlight"
    highlight.FillTransparency = 1
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0
    highlight.Parent = model
end

-- LOOP DE ATUALIZAÇÃO ÚNICO (RenderStepped Otimizado)
RunService.RenderStepped:Connect(function()
    local charLocal = localPlayer.Character
    local rootLocal = charLocal and charLocal:FindFirstChild("HumanoidRootPart")

    -- PROCESSAR TODOS OS MODELOS NO WORKSPACE (Players e NPCs)
    -- Otimização: Varremos apenas modelos que possuam Humanoid
    for _, model in pairs(workspace:GetDescendants()) do
        local humanoid = model:IsA("Model") and model:FindFirstChildOfClass("Humanoid")
        local head = model:FindFirstChild("Head")
        
        if humanoid and head and model ~= charLocal then
            local isPlayer = Players:GetPlayerFromCharacter(model)
            local distance = rootLocal and (rootLocal.Position - head.Position).Magnitude or 999
            
            -- Lógica para PLAYER
            if isPlayer and _G.ViewPlayerActive and distance <= MAX_DISTANCE then
                local p = isPlayer
                local teamColor = p.TeamColor.Color
                applyOutline(model, teamColor)
                
                local gui = head:FindFirstChild("ViewSystemUI") or createHeadUI(head)
                gui.Enabled = true
                
                -- Organizacao: Nome na Cor do Time
                gui.NameLabel.Text = string.format('<font color="rgb(%d,%d,%d)">👤: %s</font>', teamColor.R*255, teamColor.G*255, teamColor.B*255, p.DisplayName)
                -- Status: Distancia e Vida
                gui.StatsLabel.Text = string.format('<font color="%s">📏: %dM.</font> | <font color="%s">❤: %d</font>', corAmareloEscuro, math.floor(distance), corVermelhoEscuro, math.floor(humanoid.Health))
            
            -- Lógica para BOT (NPC)
            elseif not isPlayer and _G.ViewBotActive and distance <= MAX_DISTANCE then
                applyOutline(model, Color3.fromRGB(255, 0, 0))
                
                local gui = head:FindFirstChild("ViewSystemUI") or createHeadUI(head)
                gui.Enabled = true
                
                -- Organizacao: Nome em Vermelho Forte
                gui.NameLabel.Text = string.format('<font color="%s">🤖: %s</font>', corBotRed, model.Name)
                -- Status: Distancia e Vida
                gui.StatsLabel.Text = string.format('<font color="%s">📏: %dM.</font> | <font color="%s">❤: %d</font>', corAmareloEscuro, math.floor(distance), corVermelhoEscuro, math.floor(humanoid.Health))
            
            -- LIMPEZA (Se estiver fora da distância ou desativado)
            else
                clearViewElements(model)
            end
        end
    end
end)
