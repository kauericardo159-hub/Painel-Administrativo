-- 3. FUNÇÃO DE CRIAÇÃO (Com Upgrade na Lógica)
local function CreateToggle(name, labelText, posX, linkScript)
    local container = Instance.new("Frame")
    container.Name = name .. "Container"
    container.Size = UDim2.new(0, 140, 0, 65)
    container.Position = UDim2.new(posX, 0, 0.72, 0)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.Parent = miniPainel

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 25)
    iconLabel.Position = UDim2.new(0, 0, -0.1, 0)
    iconLabel.Text = labelText
    iconLabel.TextColor3 = Color3.new(1, 1, 1)
    iconLabel.Font = Enum.Font.GothamMedium
    iconLabel.TextSize = 15
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = container

    -- Base do Botão (Switch)
    local btnBase = Instance.new("TextButton")
    btnBase.Size = UDim2.new(0, 58, 0, 26)
    btnBase.Position = UDim2.new(0.5, 0, 0.65, 0)
    btnBase.AnchorPoint = Vector2.new(0.5, 0.5)
    btnBase.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Inicia Vermelho
    btnBase.Text = ""
    btnBase.AutoButtonColor = false
    btnBase.Parent = container

    Instance.new("UICorner", btnBase).CornerRadius = UDim.new(1, 0)
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1.6
    btnStroke.Color = Color3.new(1, 1, 1)
    btnStroke.Transparency = 0.6
    btnStroke.Parent = btnBase

    -- Círculo Deslizante (Knob)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0.1, 0, 0.5, 0)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = btnBase
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- LÓGICA DE UPGRADE: Executa script externo ao clicar
    local isLoaded = false
    btnBase.MouseButton1Click:Connect(function()
        isLoaded = not isLoaded
        
        local targetPos = isLoaded and UDim2.new(0.9, -20, 0.5, 0) or UDim2.new(0.1, 0, 0.5, 0)
        local targetColor = isLoaded and Color3.fromRGB(0, 160, 0) or Color3.fromRGB(150, 0, 0)

        TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = targetPos}):Play()
        TweenService:Create(btnBase, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()

        -- EXECUÇÃO DO SCRIPT EXTERNO (Seguro)
        if linkScript ~= "" then
            task.spawn(function()
                local success, err = pcall(function()
                    loadstring(game:HttpGet(linkScript))()
                end)
                if not success then
                    warn("Erro ao executar script: " .. tostring(err))
                end
            end)
        end
    end)
end

