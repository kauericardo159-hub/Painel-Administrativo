-- LOOP DE PERFORMANCE
-- ==========================================
local lastScan = 0

_G.SystemViewItensDoorsConnection = RunService.RenderStepped:Connect(function()
    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
