-- ==========================================
-- CONFIGURAÇÕES RESTRITAS E PALAVRAS-CHAVE
-- ==========================================
local MAX_DISTANCE = 100 -- Limite de 100 metros
local SCAN_INTERVAL = 0.3 -- Varredura a cada 0.3s para FPS alto

_G.SystemItensDoorsFolder = Instance.new("Folder")
_G.SystemItensDoorsFolder.Name = "DoorsItensVisuals"
_G.SystemItensDoorsFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.ItensDoorsCache = {}
local itemCache = _G.ItensDoorsCache

-- Usando trechos de palavras para não errar o nome exato (tudo minúsculo)
local KEYWORDS = {
    "gold", "coin", "key", "lighter", "flash", "candle", "bulk",
    "vitamin", "bandage", "crucifix", "skeleton", "fuse", "battery",
    "breaker", "shear", "lockpick", "book", "chest", "loot"
}

-- ==========================================
-- FUNÇÕES DE CRIAÇÃO
-- ==========================================
local function createItemVisual(obj, isDoor)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "ItemESP"
    hl.FillTransparency = 0.6
    hl.OutlineTransparency = 0
    -- Verde para porta, Ciano para itens
    local color = isDoor and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(0, 255, 255)
    hl.FillColor = color
    hl.OutlineColor = color
    hl.Parent = obj
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "ItemInfo"
    bg.Size = UDim2.new(0, 150, 0, 40)
    bg.AlwaysOnTop = true
    bg.Parent = _G.SystemItensDoorsFolder
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 13
    textLabel.TextColor3 = color
    textLabel.TextStrokeTransparency = 0.5
    textLabel.RichText = true
    textLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.Label = textLabel
    data.IsDoor = isDoor
    return data
end

-- ==========================================
-- LÓGICA DE DETECÇÃO (Palavras-Chave)
-- ==========================================
local function checkItemStatus(obj)
    if not obj:IsA("Model") and not obj:IsA("BasePart") then return false, false end

    local name = string.lower(obj.Name)

    -- 1. Verifica Portas Verdadeiras
    if name == "door" or string.find(name, "door_") then
        -- A porta certa geralmente tem um Sign (Placa) ou Lock (Cadeado) associado a ela
        if obj:FindFirstChild("Lock") or obj:FindFirstChild("Sign") or obj:FindFirstChild("Hidden") then
            return true, true -- (É válido, É porta)
        end
    end

    -- 2. Verifica Itens por palavra-chave
    for _, kw in ipairs(KEYWORDS) do
        if string.find(name, kw) then
            return true, false -- (É válido, Não é porta)
        end
    end

    return false, false
end

-- ==========================================
-- LOOP DE PERFORMANCE
-- ==========================================
local lastScan = 0

_G.SystemViewItensDoorsConnection = RunService.RenderStepped:Connect(function()
    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 1. VARREDURA OTIMIZADA
    if tick() - lastScan > SCAN_INTERVAL then
        lastScan = tick()
        for _, obj in ipairs(workspace:GetDescendants()) do
            local isValid, isDoor = checkItemStatus(obj)
            
            if isValid then
                local root = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
                if root then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist <= MAX_DISTANCE then
                        if not itemCache[obj] then
                            itemCache[obj] = createItemVisual(obj, isDoor)
                        end
                    end
                end
            end
        end
    end

    -- 2. ATUALIZAÇÃO DE UI E DISTÂNCIA
    for obj, vis in pairs(itemCache) do
        if obj and obj.Parent then
            local root = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
            if root then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist <= MAX_DISTANCE then
                    vis.UI.Adornee = root
                    vis.UI.Enabled = true
                    vis.Highlight.Enabled = true
                    
                    local displayName = vis.IsDoor and "🚪 SAÍDA" or obj.Name
                    vis.Label.Text = string.format("%s\n<font color='#FFFFFF'>[%dm]</font>", displayName, math.floor(dist))
                else
                    -- Oculta se passar de 100m
                    vis.UI.Enabled = false
                    vis.Highlight.Enabled = false
                end
            end
        else
            -- Destrói visual se o item sumir (for pego)
            vis.UI:Destroy()
            vis.Highlight:Destroy()
            itemCache[obj] = nil
        end
    end
end)
