-- ==========================================
-- CONFIGURAÇÕES RESTRITAS
-- ==========================================
local MAX_DISTANCE = 100 -- Limite solicitado
local SCAN_INTERVAL = 0.3 -- Varredura eficiente para poupar FPS

_G.SystemItensDoorsFolder = Instance.new("Folder")
_G.SystemItensDoorsFolder.Name = "DoorsItensVisuals"
_G.SystemItensDoorsFolder.Parent = localPlayer:WaitForChild("PlayerGui")

_G.ItensDoorsCache = {}
local itemCache = _G.ItensDoorsCache

-- Filtro restrito apenas para o que é coletável ou crucial
local COLLECTABLE_ITEMS = {
    ["Key"] = true, ["MasterKey"] = true, ["LibraryKey"] = true, ["ElevatorKey"] = true, -- Chaves
    ["Lighter"] = true, ["Flashlight"] = true, ["Candle"] = true, ["Bulklight"] = true, -- Luz
    ["Vitamins"] = true, ["Bandage"] = true, ["Crucifix"] = true, ["SkeletonKey"] = true, -- Utilitários
    ["Gold"] = true, ["Coin"] = true, -- Dinheiro
    ["Battery"] = true, ["Fuse"] = true, ["Breaker"] = true, -- Puzzles
    ["Shears"] = true, ["Lockpick"] = true, ["Book"] = true, -- Específicos
    ["Door"] = true -- Portas Verdadeiras
}

-- ==========================================
-- FUNÇÕES DE CRIAÇÃO
-- ==========================================
local function createItemVisual(obj)
    local data = {}
    
    local hl = Instance.new("Highlight")
    hl.Name = "ItemESP"
    hl.FillTransparency = 0.7
    hl.OutlineTransparency = 0
    hl.Parent = obj
    
    local bg = Instance.new("BillboardGui")
    bg.Name = "ItemInfo"
    bg.Size = UDim2.new(0, 150, 0, 40)
    bg.AlwaysOnTop = true
    bg.Parent = _G.SystemItensDoorsFolder
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 13
    textLabel.TextStrokeTransparency = 0.5
    textLabel.RichText = true
    textLabel.Parent = bg
    
    data.Highlight = hl
    data.UI = bg
    data.Label = textLabel
    return data
end

-- ==========================================
-- LÓGICA DE DETECÇÃO (Door & Rooms)
-- ==========================================
local function isValidItem(obj)
    -- Detecção de Itens Coletáveis e Portas
    if COLLECTABLE_ITEMS[obj.Name] then
        if obj.Name == "Door" then
            -- Verifica se é a porta verdadeira (Doors geralmente nomeia a correta de forma diferente ou usa atributos)
            if obj:FindFirstChild("Lock") or obj:FindFirstChild("Door") then return true end
            return false -- Ignora portas falsas
        end
        return true
    end
    return false
end

