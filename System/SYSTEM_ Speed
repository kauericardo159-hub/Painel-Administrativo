local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- Função para aplicar velocidade com segurança
local function applySpeed(speed)
    local char = localPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = speed
    end
end

-- ==========================================
-- GERENCIADOR DE ESTADO (Robusto)
-- ==========================================
if not _G.SystemSpeedConnection then
    print("[SYSTEM] Speed: INICIADO")
    
    -- Usamos uma tabela simples local para guardar o alvo
    local speedData = {Target = 16}                

    _G.SystemSpeedConnection = RunService.Heartbeat:Connect(function()
        applySpeed(speedData.Target)
    end)
    
    -- Criamos uma função global simples para o painel chamar
    _G.UpdateSpeedTarget = function(newSpeed)
        speedData.Target = newSpeed
        print("[SYSTEM] Alvo de velocidade atualizado para: " .. newSpeed)
        applySpeed(newSpeed)
    end
    
    -- Limpeza ao sair do jogo
    localPlayer.AncestryChanged:Connect(function()
        if not localPlayer:IsDescendantOf(game) then
            if _G.SystemSpeedConnection then _G.SystemSpeedConnection:Disconnect() end
            _G.SystemSpeedConnection = nil
            _G.UpdateSpeedTarget = nil
        end
    end)
end
