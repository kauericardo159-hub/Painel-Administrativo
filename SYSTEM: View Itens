local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES
local MAX_DISTANCE = 100
local SCAN_RATE = 0.5 -- Scaneia o Workspace inteiro a cada 0.5 segundos (não a cada frame)
local UPDATE_RATE = 0.1 -- Atualiza distâncias e UIs a cada 0.1 segundos

_G.ViewItensActive = _G.ViewItensActive or false

local activeHighlights = {}
local activeUIs = {}

-- Função de limpeza rápida
local function clearItem(obj, handle)
    if activeHighlights[obj] then 
        activeHighlights[obj]:Destroy() 
        activeHighlights[obj] = nil 
    end
    if handle and activeUIs[handle] then 
        activeUIs[handle]:Destroy() 
        activeUIs[handle] = nil 
    end
end

-- Função de limpeza forçada (ao desativar)
local function forceFullCleanup()
    for obj, hl in pairs(activeHighlights) do if hl then hl:Destroy() end end
    for handle, ui in pairs(activeUIs) do if ui then ui:Destroy() end end
    table.clear(activeHighlights)
    table.clear(activeUIs)
end

-- Validação rápida
local function isValidItem(obj)
    -- Ignora se for o próprio player ou já estiver marcado
    if not (obj:IsA("Tool") or (obj:IsA("Model") and obj:FindFirstChild("Handle"))) then return false end
    
    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    if not handle or handle.Transparency > 0.5 then return false end

    -- Ignora se estiver na mão de alguém
    local root = obj.Parent
    while root and root ~= workspace do
        if root:FindFirstChildOfClass("Humanoid") then return false end
        root = root.Parent
    end

    -- Filtro de nome
    local name = obj.Name:lower()
    if name:find("door") or name:find("porta") or name:find("gate") then return false end

    return true
end

-- LOOPS SEPARADOS PARA PERFORMANCE
-- Loop 1: Varredura de Itens (Lento - 2x por segundo)
task.spawn(function()
    while true do
        if _G.ViewItensActive then
            for _, obj in pairs(workspace:GetDescendants()) do
                if isValidItem(obj) then
                    -- Marca que precisa de outline se não tiver
                    if not activeHighlights[obj] then
                        local hl = Instance.new("Highlight")
                        hl.Name = "ItemHighlight"
                        hl.FillTransparency = 1
                        hl.OutlineColor = Color3.fromRGB(255, 120, 0)
                        hl.Parent = obj
                        activeHighlights[obj] = hl
                    end
                else
                    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
                    clearItem(obj, handle)
                end
            end
        end
        task.wait(SCAN_RATE)
    end
end)

-- Loop 2: Atualização de Distância e UI (Rápido - 10x por segundo)
RunService.Heartbeat:Connect(function()
    if not _G.ViewItensActive then
        if next(activeHighlights) or next(activeUIs) then forceFullCleanup() end
        return
    end

    local char = localPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for obj, hl in pairs(activeHighlights) do
        local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
        if handle and hl.Parent then
            local dist = (hrp.Position - handle.Position).Magnitude
            
            if dist <= MAX_DISTANCE then
                -- Atualiza UI
                local ui = activeUIs[handle]
                if not ui then
                    -- Cria UI se não existir
                    local billboard = Instance.new("BillboardGui")
                    billboard.Name = "ItemViewUI"
                    billboard.Size = UDim2.new(0, 150, 0, 40)
                    billboard.StudsOffset = Vector3.new(0, 2, 0)
                    billboard.AlwaysOnTop = true
                    billboard.LightInfluence = 0
                    billboard.Parent = handle
                    
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Font = Enum.Font.GothamBold
                    label.TextColor3 = Color3.fromRGB(255, 120, 0)
                    label.TextSize = 13
                    label.TextStrokeTransparency = 0.5
                    label.RichText = true
                    label.Parent = billboard
                    activeUIs[handle] = billboard
                    ui = billboard
                end
                ui.Enabled = true
                ui.TextLabel.Text = string.format("📦 %s\n<font color='rgb(200,200,0)'>📏 %dM.</font>", obj.Name, math.floor(dist))
            else
                -- Longe demais
                if activeUIs[handle] then activeUIs[handle].Enabled = false end
            end
        else
            -- Item deletado ou inválido
            clearItem(obj, handle)
        end
    end
end)
