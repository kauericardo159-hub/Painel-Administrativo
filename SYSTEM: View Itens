local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES
local MAX_DISTANCE = 100
local UPDATE_RATE = 0.1 -- Atualiza a cada 0.1 segundos

_G.ViewItensActive = _G.ViewItensActive or false

local trackedItems = {}
local connections = {}
local wasActive = false

-- TEMPLATES: Criamos a UI uma vez e só clonamos depois (muito mais leve)
local uiTemplate = Instance.new("BillboardGui")
uiTemplate.Name = "ItemViewUI"
uiTemplate.Size = UDim2.new(0, 150, 0, 40)
uiTemplate.StudsOffset = Vector3.new(0, 2, 0)
uiTemplate.AlwaysOnTop = true
uiTemplate.LightInfluence = 0
uiTemplate.Enabled = false

local labelTemplate = Instance.new("TextLabel")
labelTemplate.Size = UDim2.new(1, 0, 1, 0)
labelTemplate.BackgroundTransparency = 1
labelTemplate.Font = Enum.Font.GothamBold
labelTemplate.TextColor3 = Color3.fromRGB(255, 120, 0)
labelTemplate.TextSize = 13
labelTemplate.TextStrokeTransparency = 0.5
labelTemplate.RichText = true
labelTemplate.Parent = uiTemplate

-- Validação Otimizada
local function isValidItem(obj)
    -- Filtro principal rápido (Ignora 99% do mapa imediatamente)
    if not (obj:IsA("Tool") or (obj:IsA("Model") and obj:FindFirstChild("Handle"))) then return false end
    
    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    if not handle or handle.Transparency > 0.5 then return false end

    -- Filtro de nome
    local name = obj.Name:lower()
    if name:find("door") or name:find("porta") or name:find("gate") then return false end

    -- Verifica se está na mão de alguém (Ancestry)
    local root = obj.Parent
    while root and root ~= Workspace do
        if root:FindFirstChildOfClass("Humanoid") then return false end
        root = root.Parent
    end

    return true, handle
end

-- Registro do Item
local function registerItem(obj)
    if trackedItems[obj] then return end -- Já está registrado
    
    local valid, handle = isValidItem(obj)
    if not valid then return end

    local hl = Instance.new("Highlight")
    hl.Name = "ItemHighlight"
    hl.FillTransparency = 1
    hl.OutlineColor = Color3.fromRGB(255, 120, 0)
    hl.Enabled = false -- Começa desativado para poupar performance
    hl.Parent = obj

    local ui = uiTemplate:Clone()
    ui.Parent = handle

    -- Salva na tabela para fácil acesso no loop
    trackedItems[obj] = {
        Handle = handle,
        Highlight = hl,
        UI = ui,
        TextLabel = ui.TextLabel,
        Name = obj.Name
    }
end

-- Desregistro e Limpeza Segura
local function unregisterItem(obj)
    local data = trackedItems[obj]
    if data then
        if data.Highlight then data.Highlight:Destroy() end
        if data.UI then data.UI:Destroy() end
        trackedItems[obj] = nil
    end
end

-- GERENCIADOR PRINCIPAL (Substitui os 2 loops antigos)
task.spawn(function()
    while true do
        task.wait(UPDATE_RATE)
        
        local isActive = _G.ViewItensActive == true
        
        -- SISTEMA LIGA/DESLIGA INTELIGENTE
        if isActive and not wasActive then
            wasActive = true
            -- Varredura inicial (apenas uma vez!)
            for _, obj in pairs(Workspace:GetDescendants()) do
                registerItem(obj)
            end
            -- Ouve novos itens caindo no mapa
            connections.Added = Workspace.DescendantAdded:Connect(registerItem)
            connections.Removing = Workspace.DescendantRemoving:Connect(unregisterItem)
            
        elseif not isActive and wasActive then
            wasActive = false
            -- Limpa tudo se for desativado
            if connections.Added then connections.Added:Disconnect() end
            if connections.Removing then connections.Removing:Disconnect() end
            for obj in pairs(trackedItems) do
                unregisterItem(obj)
            end
        end
        
        -- ATUALIZAÇÃO DE DISTÂNCIA E UI
        if isActive then
            local char = localPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            
            local hrpPos = hrp.Position
            local highlightCount = 0 -- O Roblox crasha/buga se passar de 31 Highlights
            
            for obj, data in pairs(trackedItems) do
                -- Verificação extra: o item foi pego por um jogador?
                if not obj.Parent or obj.Parent:FindFirstChildOfClass("Humanoid") then
                    unregisterItem(obj)
                    continue
                end

                local dist = (hrpPos - data.Handle.Position).Magnitude
                
                if dist <= MAX_DISTANCE then
                    data.UI.Enabled = true
                    data.UI.TextLabel.Text = string.format("📦 %s\n<font color='rgb(200,200,0)'>📏 %dM.</font>", data.Name, math.floor(dist))
                    
                    -- Limita os Highlights aos 30 itens mais próximos/detectados
                    if highlightCount < 30 then
                        data.Highlight.Enabled = true
                        highlightCount += 1
                    else
                        data.Highlight.Enabled = false
                    end
                else
                    -- Esconde UI e Highlight se estiver longe
                    data.UI.Enabled = false
                    data.Highlight.Enabled = false
                end
            end
        end
    end
end)
